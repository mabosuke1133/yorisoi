<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <%# --- 投稿メイン部分 --- %>
      <div class="card shadow-sm border-0 rounded-lg overflow-hidden mb-4">
        <% if @post.image.attached? %>
          <%= image_tag @post.image, class: "card-img-top", style: "height: 400px; object-fit: cover;" %>
        <% end %>
        
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 font-weight-bold mb-0"><%= @post.title %></h1>
            
            <%# 🆕 シグナルの表示を更新（独り言・聞いて・SOS） %>
            <% if @post.priority == 5 %>
              <span class="badge badge-danger p-2 shadow-sm animate-pulse"><i class="fas fa-exclamation-triangle"></i> 緊急SOS</span>
            <% elsif @post.priority == 1 %>
              <span class="badge badge-info p-2 text-white"><i class="fas fa-seedling"></i> 独り言</span>
            <% else %>
              <span class="badge badge-success p-2"><i class="fas fa-leaf"></i> 聞いて</span>
            <% end %>
          </div>

          <p class="text-muted mb-4" style="line-height: 1.8; white-space: pre-wrap;"><%= @post.body %></p>

          <div class="d-flex justify-content-between align-items-center border-top pt-3">
            <div class="d-flex align-items-center">
              <%# 投稿者情報 %>
              <div class="text-muted small mr-3">
                投稿者: <%= link_to @post.user.name, user_path(@post.user), class: "font-weight-bold text-success" %>
              </div>
              
              <%# いいねボタン %>
              <div class="small">
                <%= render 'favorites/favorite_btn', post: @post %>
              </div>
            </div>
            
            <%# 編集・削除ボタン（自分の投稿の場合のみ） %>
            <div>
              <% if @post.user == current_user %>
                <%= link_to '編集', edit_post_path(@post), class: "btn btn-outline-secondary btn-sm rounded-pill px-3 mr-2" %>
                <%# 🆕 confirm_post_path ではなく直接 delete するように修正 %>
                <%= link_to '削除', post_path(@post), method: :delete, data: { confirm: 'このつぶやきを削除してもよろしいですか？' }, class: "btn btn-outline-danger btn-sm rounded-pill px-3" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%= link_to '← タイムラインに戻る', posts_path, class: "text-muted mb-5 d-block" %>

      <hr class="my-5">

      <%# --- コメント一覧部分 --- %>
      <h4 class="mb-4"><i class="far fa-comments text-success"></i> 寄り添いメッセージ（<%= @post.post_comments.count %>件）</h4>
      
      <div class="comments-section mb-5">
        <% @post.post_comments.each do |post_comment| %>
          <div class="card mb-3 border-0 shadow-sm rounded-lg">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center mb-2">
                  <span class="font-weight-bold text-dark small mr-2">
                    <%= post_comment.user.name %>
                  </span>
                  <span class="text-muted small">
                    <%= post_comment.created_at.strftime('%Y/%m/%d %H:%M') %>
                  </span>
                </div>
                
                <%# 自分のコメントなら削除ボタンを表示 %>
                <% if post_comment.user == current_user %>
                  <%= link_to post_post_comment_path(post_comment.post, post_comment), method: :delete, data: { confirm: 'メッセージを削除しますか？' }, class: "text-danger small" do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                <% end %>
              </div>
              
              <p class="mb-0 text-secondary" style="white-space: pre-wrap;"><%= post_comment.comment %></p>
            </div>
          </div>
        <% end %>
      </div>

      <hr class="my-5">

      <%# --- コメント投稿フォーム --- %>
      <div class="new-comment-form bg-light p-4 rounded-lg shadow-sm mb-5">
        <h5 class="mb-3 font-weight-bold text-success">
          <i class="fas fa-pen-nib"></i> メッセージを贈る
        </h5>
        
        <%# 💡 @post と @post_comment の2つを渡すのが Rails のルールです %>
        <%= form_with model: [@post, @post_comment], local: true do |f| %>
          <div class="form-group">
            <%= f.text_area :comment, rows: '3', class: "form-control border-0 shadow-sm", placeholder: "ここに想いを綴ってみましょう..." %>
          </div>
          <div class="text-right">
            <%= f.submit "メッセージを届ける", class: "btn btn-success rounded-pill px-5 shadow-sm" %>
          </div>
        <% end %>
      </div>

    </div> <%# col-md-8 の閉じ %>
  </div> <%# row の閉じ %>
</div> <%# container の閉じ %>
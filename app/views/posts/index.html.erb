<div class="container mt-4">
  <%# ヘッダー部分 %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="font-weight-bold text-success d-inline-block mr-2">みんなの広場</h2>
      <span class="badge badge-pill badge-light text-muted p-2 shadow-sm">
        全 <%= @posts.count %> 件の想い
      </span>
    </div>
    
    <%= link_to new_post_path, class: "btn btn-success rounded-pill px-4 shadow-sm" do %>
      <i class="fas fa-paper-plane"></i> つぶやきを届ける
    <% end %>
  </div>

  <%# 🔍 検索フォーム %>
  <div class="search_form mb-5 p-4 bg-white rounded shadow-sm border text-center">
    <p class="small text-muted mb-3"><i class="fas fa-search"></i> 気になるキーワードで投稿を探してみましょう</p>
    <%= form_with url: posts_path, method: :get, local: true, class: "form-inline justify-content-center" do |f| %>
      <%= f.text_field :keyword, value: params[:keyword], class: "form-control mr-sm-2 rounded-pill w-50", placeholder: "キーワードを入力..." %>
      <%= f.submit "検索", class: "btn btn-success rounded-pill px-4 shadow-sm" %>
    <% end %>
  </div>

  <%# 投稿カード一覧 %>
  <div class="row">
    <% @posts.each do |post| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0 rounded-lg overflow-hidden <%= 'border-sos animate-pulse' if post.priority == 5 %>">
          
          <%# 1. 画像エリア %>
          <div class="post-image-container bg-light text-center">
            <% if post.image.attached? %>
              <%= image_tag post.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
            <% else %>
              <div class="py-5 text-muted"><i class="fas fa-image"></i> 画像なし</div>
            <% end %>
          </div>

          <%# 2. ボディエリア %>
          <div class="card-body">
            <div class="mb-2">
              <% if post.priority == 5 %>
                <span class="badge badge-danger p-2 shadow-sm"><i class="fas fa-exclamation-triangle"></i> 緊急SOS</span>
              <% elsif post.priority == 1 %>
                <span class="badge badge-info p-2 text-white"><i class="fas fa-seedling"></i> おだやか</span>
              <% else %>
                <span class="badge badge-success p-2"><i class="fas fa-leaf"></i> きいて</span>
              <% end %>
            </div>
            
            <h5 class="card-title font-weight-bold text-dark mb-1">
              <%= post.title %>
            </h5>
            
            <p class="text-muted small mb-0">
              <i class="fas fa-user"></i> <%= post.user.name %> さん
            </p>
          </div>

          <%# 3. フッターエリア（削除ボタンを追加） %>
          <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center pb-3">
            <div class="d-flex align-items-center">
              <span class="small text-muted mr-3">
                <i class="far fa-comment-dots"></i> <%= post.post_comments.count %>
              </span>
              <span class="small">
                <%= render 'favorites/favorite_btn', post: post %>
              </span>
            </div>

            <div class="d-flex align-items-center">
              <%# 🆕 投稿者本人の場合のみ削除ボタンを表示 %>
              <% if post.user == current_user %>
                <%= link_to '削除', post_path(post), method: :delete, data: { confirm: 'このつぶやきを削除してもよろしいですか？' }, class: 'text-danger small mr-3' %>
              <% end %>
              <%= link_to '詳細を見る', post_path(post), class: 'btn btn-outline-success btn-sm rounded-pill px-3' %>
            </div>
          </div>

        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .border-sos {
    border: 2px solid #dc3545 !important;
    box-shadow: 0 0 15px rgba(220, 53, 69, 0.3) !important;
  }
  
  .animate-pulse {
    animation: pulse 2.5s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }
</style>
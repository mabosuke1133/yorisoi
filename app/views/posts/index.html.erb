<div class="container mt-4 pb-5">
  <%# --- 1. 広場のヘッダー --- %>
  <div class="text-center mb-5 py-4 bg-white rounded-xl shadow-sm border">
    <h2 class="font-weight-bold text-success mb-2">
      <i class="fas fa-comments mr-2"></i>みんなの広場
    </h2>
    <p class="text-muted small mb-0">
      ここは、チームを越えて「いまの気持ち」をそっと置ける場所です。<br class="d-none d-md-inline">
      誰かの投稿に「わかる」と思ったら、寄り添いボタンで共感を届けましょう。
    </p>
    
    <div class="mt-4">
      <% if user_signed_in? %>
        <%= link_to new_post_path, class: "btn btn-success rounded-pill px-5 py-2 shadow-sm font-weight-bold" do %>
          <i class="fas fa-feather-alt mr-1"></i> 今の気持ちを投稿する
        <% end %>
      <% end %>
    </div>
  </div>

  <%# --- 2. 投稿一覧（カード形式） --- %>
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
      
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div class="card mb-4 border-0 shadow-sm rounded-xl hover-up transition">
            <div class="card-body p-4">
              <div class="d-flex align-items-start">
                
                <%# 左側：レベルに応じたアイコンバッジ %>
                <div class="mr-3 text-center" style="width: 60px;">
                  <% case post.priority %>
                  <% when "soliloquy", 1 # 独り言 %>
                    <div class="icon-circle bg-light-success text-success mb-1" title="独り言">
                      <i class="fas fa-comment-dots"></i>
                    </div>
                    <span class="badge badge-pill badge-success-light">独り言</span>
                  <% when "sos", 3 # SOS %>
                    <div class="icon-circle bg-light-danger text-danger mb-1" title="SOS">
                      <i class="fas fa-exclamation-circle"></i>
                    </div>
                    <span class="badge badge-pill badge-danger-light">SOS</span>
                  <% else # 聞いて %>
                    <div class="icon-circle bg-light-warning text-warning mb-1" title="聞いて">
                      <i class="fas fa-bullhorn"></i>
                    </div>
                    <span class="badge badge-pill badge-warning-light">聞いて</span>
                  <% end %>
                </div>

                <%# 右側：メインコンテンツ %>
                <div class="flex-grow-1">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong class="text-dark"><%= post.user.name %> さん</strong>
                    <small class="text-muted"><%= time_ago_in_words(post.created_at) %>前</small>
                  </div>
                  
                  <div class="post-content text-secondary mb-3" style="line-height: 1.6; white-space: pre-wrap;">
                    <%= post.body %>
                  </div>

                  <%# 下部：アクションエリア %>
                  <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                    <div class="reaction-buttons">
                      <% if user_signed_in? %>
                        <%# --- 1. 一般ユーザー：寄り添い判定を行う --- %>
                        <% if current_user.already_favorited?(post) %>
                          <%= link_to post_favorites_path(post), method: :delete, class: "btn btn-sm text-danger border-0 rounded-pill px-3 bg-light" do %>
                            <i class="fas fa-heart mr-1"></i> 寄り添い中 <%= post.favorites.count %>
                          <% end %>
                        <% else %>
                          <%= link_to post_favorites_path(post), method: :post, class: "btn btn-sm text-muted border-0 rounded-pill px-3 bg-light" do %>
                            <i class="far fa-heart mr-1"></i> 寄り添う <%= post.favorites.count %>
                          <% end %>
                        <% end %>

                      <% elsif admin_signed_in? %>
                        <%# --- 2. 管理者：表示のみ（NilClassエラー回避） --- %>
                        <span class="btn btn-sm text-muted border-0 rounded-pill px-3 bg-light disabled">
                          <i class="fas fa-heart mr-1"></i> <%= post.favorites.count %>
                        </span>

                      <% else %>
                        <%# --- 3. 未ログイン：ログイン画面へ誘導 --- %>
                        <%= link_to new_user_session_path, class: "btn btn-sm text-muted border-0 rounded-pill px-3 bg-light" do %>
                          <i class="far fa-heart mr-1"></i> 寄り添う <%= post.favorites.count %>
                        <% end %>
                      <% end %>
                    </div>
                    
                    <div>
                      <%= link_to post_path(post), class: "text-success small font-weight-bold" do %>
                        詳細を見る <i class="fas fa-chevron-right ml-1"></i>
                      <% end %>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-5 bg-white rounded-xl shadow-sm border">
          <i class="fas fa-leaf fa-3x text-muted opacity-25 mb-3"></i>
          <h5 class="text-secondary">まだ投稿がありません</h5>
          <p class="text-muted small">最初の一言を投稿してみませんか？</p>
        </div>
      <% end %>

    </div>
  </div>
</div>

<style>
  .rounded-xl { border-radius: 1.25rem; }
  .hover-up:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important;
  }
  .transition { transition: all 0.3s ease; }
  
  .icon-circle {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    margin: 0 auto;
  }

  .bg-light-success { background-color: #e8f5e9; }
  .bg-light-warning { background-color: #fff3e0; }
  .bg-light-danger  { background-color: #ffebee; }
  
  .badge-success-light { background-color: #c8e6c9; color: #2e7d32; }
  .badge-warning-light { background-color: #ffe0b2; color: #ef6c00; }
  .badge-danger-light  { background-color: #ffcdd2; color: #c62828; }

  .post-content {
    font-size: 1rem;
    word-break: break-all;
  }
</style>
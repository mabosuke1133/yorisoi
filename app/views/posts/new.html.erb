<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <h2 class="text-center mb-4 font-weight-bold text-success">つぶやきを届ける</h2>
          <p class="text-muted text-center mb-5 small">今の気持ちや現場での気づきを、みんなに届けてみましょう。</p>

          <%= form_with model: @post, local: true do |f| %>
            <div class="form-group mb-4">
              <%= f.label :title, "タイトル", class: "font-weight-bold" %>
              <%= f.text_field :title, class: "form-control form-control-lg bg-light border-0", placeholder: "一言で表すと？" %>
            </div>

            <div class="form-group mb-4">
              <%= f.label :body, "内容", class: "font-weight-bold" %>
              <%= f.text_area :body, class: "form-control bg-light border-0", rows: 6, placeholder: "今の気持ちをとことん書いてみましょう" %>
            </div>

            <div class="text-center mt-5">
              <%= f.submit "みんなに届ける", class: "btn btn-success btn-lg rounded-pill px-5 shadow" %>
              <div class="mt-3">
                <%= link_to '戻る', posts_path, class: "text-muted small" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
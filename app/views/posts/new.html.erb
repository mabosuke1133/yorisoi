<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <%# --- タイトルエリア --- %>
          <h2 class="text-center mb-4 font-weight-bold text-success">つぶやきを届ける</h2>
          <p class="text-muted text-center mb-5 small">今の気持ちや現場での気づきを、みんなに届けてみましょう。</p>

          <%= form_with model: @post, local: true do |f| %>
            <%# --- 1. タイトル入力 --- %>
            <div class="form-group mb-4">
              <%= f.label :title, "タイトル", class: "font-weight-bold" %>
              <%= f.text_field :title, class: "form-control form-control-lg bg-light border-0", placeholder: "一言で表すと？" %>
            </div>

            <%# --- 2. 本文入力 --- %>
            <div class="form-group mb-4">
              <%= f.label :body, "内容", class: "font-weight-bold" %>
              <%= f.text_area :body, class: "form-control bg-light border-0", rows: 6, placeholder: "今の気持ちをとことん書いてみましょう" %>
            </div>

            <%# --- 3. 状況選択（シグナル） --- %>
            <div class="form-group mb-4">
              <label class="font-weight-bold d-block mb-3">今の状況（シグナル）</label>
              <div class="row mx-0">
  
                <div class="col-4 px-1">
                  <%# :priority ではなく :emotion_level に変更、値も 1 に %>
                  <%= f.radio_button :emotion_level, 1, class: "sr-only custom-priority-input", id: "priority_1" %>
                  <label for="priority_1" class="btn btn-outline-info w-100 p-3 h-100 shadow-sm border-2">
                    <i class="fas fa-comment-dots"></i><br><small>独り言</small>
                  </label>
                </div>

                <div class="col-4 px-1">
                  <%# :priority ではなく :emotion_level に変更、値も 2 に %>
                  <%= f.radio_button :emotion_level, 2, class: "sr-only custom-priority-input", id: "priority_2", checked: true %>
                  <label for="priority_2" class="btn btn-outline-success w-100 p-3 h-100 shadow-sm border-2">
                    <i class="fas fa-bullhorn"></i><br><small>聞いて</small>
                  </label>
                </div>

                <div class="col-4 px-1">
                  <%# :priority ではなく :emotion_level に変更、値も 3 に %>
                  <%= f.radio_button :emotion_level, 3, class: "sr-only custom-priority-input", id: "priority_3" %>
                  <label for="priority_3" class="btn btn-outline-danger w-100 p-3 h-100 shadow-sm border-2">
                    <i class="fas fa-exclamation-circle"></i><br><small>SOS</small>
                  </label>
                </div>
              </div>
            </div>

            <%# --- 4. 送信ボタン --- %>
            <div class="text-center mt-5">
              <%= f.submit "みんなに届ける", class: "btn btn-success btn-lg rounded-pill px-5 shadow" %>
              <div class="mt-3">
                <%= link_to '戻る', posts_path, class: "text-muted small" %>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>

<%# 🆕 ボタンの選択状態を管理する専用スタイル %>
<style>
  /* チェックされた時の色付け */
  .custom-priority-input:checked + label.btn-outline-info { background-color: #17a2b8; color: white; }
  .custom-priority-input:checked + label.btn-outline-success { background-color: #28a745; color: white; }
  .custom-priority-input:checked + label.btn-outline-danger { background-color: #dc3545; color: white; }
  
  /* 枠線を少し太くして押しやすく */
  .border-2 { border-width: 2px !important; }
  /* 本物のラジオボタンを隠す */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>
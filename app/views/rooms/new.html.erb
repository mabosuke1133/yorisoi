<div class="container mt-5">
  <h2>新しい相談ルームを作成</h2>
  
  <%= form_with model: @room, local: true do |f| %>
    <div class="form-group mt-3">
      <%= f.label :name, "ルーム名（例：〇〇さんの投稿について相談）" %>
      <%= f.text_field :name, class: "form-control", placeholder: "ルーム名を入力してください" %>
    </div>
    
    <%= f.submit "ルームを作成する", class: "btn btn-primary mt-3" %>
    <%= link_to "戻る", :back, class: "btn btn-outline-secondary mt-3 ml-2" %>
  <% end %>
</div>
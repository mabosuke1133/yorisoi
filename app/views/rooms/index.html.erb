<div class="container mt-5">
  <h2>相談ルーム一覧</h2>
  <div class="row">
    <% @rooms.each do |room| %>
      <%# 💡 核心：作成者が「自分がフォローしている人」である場合のみ表示 %>
      <% if current_user.following.include?(room.user) || room.user == current_user %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= room.name %></h5>
              <p class="text-muted small">作成者: <%= room.user.name %></p>
              <p class="badge badge-info">
                参加メンバー: <%= room.entries.count %> 人
              </p>
              
              <div class="mt-3">
                <% if room.users.include?(current_user) %>
                  <%= link_to "ルームに入る", room_path(room), class: "btn btn-outline-primary btn-block" %>
                <% else %>
                  <%# 3人以上になっても、どんどん参加ボタンを表示し続ける %>
                  <%= button_to "このトークに参加する", join_room_path(room), method: :post, class: "btn btn-primary btn-block" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
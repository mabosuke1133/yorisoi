<div class="container my-5 text-center px-4">
  <%# --- 1. キャッチコピー --- %>
  <div class="py-5 mb-5 animate-fade-in">
    <h1 class="display-3 font-weight-bold text-success mb-4">Yorisoi</h1>
    <h2 class="h4 text-secondary mb-5">
      3つのレベルで、今の気分をシェアする。<br class="d-md-none">
      それだけで、誰かと繋がれる場所。
    </h2>
    
    <div class="action-buttons">
      <% if user_signed_in? %>
        <%= link_to new_post_path, class: "btn btn-success btn-lg rounded-pill px-5 py-3 shadow-sm hover-up" do %>
          <i class="fas fa-pen mr-2"></i> 今の気分を記録する
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path, class: "btn btn-success btn-lg rounded-pill px-5 py-3 shadow-sm hover-up" do %>
          アカウントを作成してはじめる
        <% end %>
      <% end %>
    </div>
  </div>

  <%# --- 2. 3段階のステータスイメージ --- %>
  <div class="row justify-content-center mb-5 py-5 bg-white rounded-xl shadow-sm border">
    <div class="col-12 mb-4">
      <p class="text-muted small font-weight-bold text-uppercase tracking-widest">Your Status Level</p>
    </div>
    
    <%# Level 1: Good %>
    <div class="col-4 col-md-3">
      <div class="status-icon-wrapper mb-2">
        <i class="fas fa-smile fa-3x text-success"></i>
      </div>
      <p class="font-weight-bold text-success mb-0">Good</p>
      <span class="small text-muted">レベル 1</span>
    </div>

    <%# Level 2: Normal %>
    <div class="col-4 col-md-3 border-left border-right">
      <div class="status-icon-wrapper mb-2">
        <i class="fas fa-meh fa-3x text-warning"></i>
      </div>
      <p class="font-weight-bold text-warning mb-0">Normal</p>
      <span class="small text-muted">レベル 2</span>
    </div>

    <%# Level 3: SOS %>
    <div class="col-4 col-md-3">
      <div class="status-icon-wrapper mb-2">
        <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
      </div>
      <p class="font-weight-bold text-danger mb-0">SOS</p>
      <span class="small text-muted">レベル 3</span>
    </div>
  </div>

  <%# --- 3. さりげない安心のメッセージ --- %>
  <div class="mt-5 pt-3">
    <p class="text-muted small mb-0">
      <i class="fas fa-lock mr-1"></i> 投稿はログインしたメンバー内だけで共有されます
    </p>
    <p class="text-muted small">
      詳しい使い方は <%= link_to 'Aboutページ', about_path, class: "text-success border-bottom" %> をご覧ください
    </p>
  </div>
</div>

<style>
  .rounded-xl { border-radius: 2rem; }
  .tracking-widest { letter-spacing: 0.3em; }
  .status-icon-wrapper {
    transition: transform 0.3s ease;
  }
  .status-icon-wrapper:hover {
    transform: scale(1.1);
  }
  .hover-up {
    transition: all 0.3s ease;
  }
  .hover-up:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-in-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
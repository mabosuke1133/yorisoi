<div class="container my-5">
  <%# --- ヒーローセクション（短く、印象的に） --- %>
  <div class="text-center py-5 mb-5 bg-white rounded shadow-sm">
    <h1 class="display-4 text-success font-weight-bold mb-3">Yorisoi</h1>
    <p class="lead text-muted">「いま」の気持ちを、ひとりにしない。</p>
    <hr class="my-4 w-25">
    
    <% if user_signed_in? %>
      <%= link_to new_post_path, class: "btn btn-success btn-lg rounded-pill px-5 shadow-sm" do %>
        <i class="fas fa-pen"></i> つぶやきを届ける
      <% end %>
    <% else %>
      <%= link_to new_user_registration_path, class: "btn btn-success btn-lg rounded-pill px-5 shadow-sm" do %>
        まずは新規登録からはじめる
      <% end %>
    <% end %>
  </div>

  <%# --- 最新のつぶやきセクション --- %>
  <div class="latest-posts-section">
    <h3 class="text-center font-weight-bold mb-4">
      <i class="fas fa-comment-dots text-success mr-2"></i>みんなの最新の想い
    </h3>
    
    <div class="row">
      <% if @latest_posts.present? %>
        <% @latest_posts.each do |post| %>
          <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm hover-up">
              <div class="card-body">
                <div class="mb-2">
                  <%# 優先度（感情レベル）に応じたバッジ表示 %>
                  <% if post.priority == 5 %>
                    <span class="badge badge-danger">SOS</span>
                  <% else %>
                    <span class="badge badge-success">Level <%= post.priority %></span>
                  <% end %>
                </div>
                <h5 class="card-title font-weight-bold text-truncate"><%= post.title %></h5>
                <p class="card-text text-muted small"><%= truncate(post.body, length: 50) %></p>
              </div>
              <div class="card-footer bg-transparent border-0 pb-3">
                <p class="small text-muted mb-0 text-right">
                  <i class="fas fa-user-circle"></i> <%= post.user.name %> さん
                </p>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-center text-muted w-100">まだ投稿がありません。最初のつぶやきを届けてみませんか？</p>
      <% end %>
    </div>

    <div class="text-center mt-4">
      <%= link_to posts_path, class: "btn btn-outline-success rounded-pill px-4" do %>
        もっと見る <i class="fas fa-chevron-right ml-1"></i>
      <% end %>
    </div>
  </div>
</div>

<style>
  .hover-up {
    transition: transform 0.3s ease;
  }
  .hover-up:hover {
    transform: translateY(-5px);
  }
</style>
</style>
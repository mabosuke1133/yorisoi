<%# --- 💡 [追記] 一般スタッフ（User）でログインした時の案内 --- %>
<% if user_signed_in? && current_user&.email == 'guest@example.com' %>
  <div class="alert alert-info shadow-sm mb-4 p-4 text-left animate-fade-in mx-auto" style="border-left: 5px solid #17a2b8; border-radius: 1rem; background-color: #e3f2fd; max-width: 800px;">
    <h4 class="h5 font-weight-bold text-info mb-2">
      <i class="fas fa-info-circle mr-1"></i> 採用担当者様へ（一般スタッフ視点チュートリアル）
    </h4>
    <p class="small text-secondary mb-3">
      スタッフから管理者へ、個別に面談を申し込む一連の流れをご体験いただけます。
    </p>
    <ol class="small text-secondary pl-3 mb-0" style="line-height: 1.6;">
      <li class="mb-1">画面上部（ヘッダー）にある<strong>「赤いボタン（面談希望ボタン）」</strong>を押します。</li>
      <li class="mb-1">これで管理者に対して「面談希望」の通知と意思表示が送られます。</li>
      <li>💡 <strong>さらに踏み込んだ体験：</strong>ボタンを押した後、一度ログアウトして「管理者としてログイン」し直す（またはシークレットウインドウ等で別ブラウザを開く）と、この面談希望に対して管理者が相談部屋を作成するデモが体験できます！</li>
    </ol>
  </div>
<% end %>

<%# --- 💡 [追記] 管理者（Admin）でログインした時の案内 --- %>
<% if admin_signed_in? && current_admin&.email == 'guest_admin@example.com' %>
  <div class="alert alert-danger shadow-sm mb-4 p-4 text-left animate-fade-in mx-auto" style="border-left: 5px solid #dc3545; border-radius: 1rem; background-color: #fdf2f2; max-width: 800px;">
    <h4 class="h5 font-weight-bold text-danger mb-2">
      <i class="fas fa-user-shield mr-1"></i> 採用担当者様へ（管理者視点チュートリアル）
    </h4>
    <p class="small text-secondary mb-3">
      スタッフからの面談希望を受け取り、サポートを開始する管理画面です。
    </p>
    <ol class="small text-secondary pl-3 mb-0" style="line-height: 1.6;">
      <li class="mb-1">一般スタッフがヘッダーの赤いボタンから「面談希望」を出していると、管理側のヘッダーにある「個別相談一覧」にそのリクエストが表示されます。</li>
      <li class="mb-1">対象のスタッフに対して <strong>「相談部屋（Message Room）を作成する」</strong> を実行してみてください。</li>
      <li>部屋が作成されると、個別チャット（メッセージ機能）を使ってリアルタイムにスタッフの相談に乗ることができます。</li>
    </ol>
  </div>
<% end %>

<div class="container my-5 text-center px-4">
  <%# --- 1. ヒーローセクション --- %>
  <div class="py-5 mb-5 animate-fade-in">
    <h1 class="display-3 font-weight-bold text-success mb-4">Yorisoi</h1>
    <h2 class="h4 text-secondary mb-5" style="line-height: 1.6;">
      言葉にできない「いま」の気分を、<br class="d-md-none">
      3つのカタチで置いていく場所。
    </h2>
    
    <div class="action-buttons mb-4">
      <% if user_signed_in? %>
        <%= link_to new_post_path, class: "btn btn-success btn-lg rounded-pill px-5 py-3 shadow-sm hover-up" do %>
          <i class="fas fa-pen mr-2"></i> 今の気持ちを届ける
        <% end %>
      <% elsif admin_signed_in? %>
        <%# 管理者ログイン時は、管理画面やメイン機能への導線に合わせて適宜リンクを変更してください %>
        <%= link_to groups_path, class: "btn btn-danger btn-lg rounded-pill px-5 py-3 shadow-sm hover-up" do %>
          <i class="fas fa-tasks mr-2"></i> 管理画面へ移動する
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path, class: "btn btn-success btn-lg rounded-pill px-5 py-3 shadow-sm hover-up" do %>
          はじめる（新規登録）
        <% end %>
      <% end %>
    </div>
  </div>

  <%# --- 💡 採用担当者様用かんたんログインエリア（未ログイン時のみ表示） --- %>
  <% unless user_signed_in? || admin_signed_in? %>
    <div class="card shadow-sm border-primary mx-1 mb-5 rounded-xl bg-light animate-fade-in" style="border: 2px dashed #007bff;">
      <div class="card-body py-4 px-3">
        <h3 class="h5 font-weight-bold text-primary mb-2">
          <i class="fas fa-eye mr-1"></i> 採用担当者様へ（ポートフォリオ閲覧用）
        </h3>
        <p class="text-muted small mb-4 mx-auto" style="max-width: 500px;">
          新規登録なしで、アプリの機能をすぐにお試しいただけます。
        </p>
        
        <div class="d-flex justify-content-center flex-wrap" style="gap: 15px;">
          <%= link_to users_guest_sign_in_path, method: :post, class: "btn btn-primary btn-lg rounded-pill px-4 shadow-sm hover-up font-weight-bold text-white" do %>
            <i class="fas fa-user mr-2"></i> 一般スタッフとしてログイン
          <% end %>
          
          <%= link_to users_guest_admin_sign_in_path, method: :post, class: "btn btn-danger btn-lg rounded-pill px-4 shadow-sm hover-up font-weight-bold text-white" do %>
            <i class="fas fa-user-shield mr-2"></i> 管理者としてログイン
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# --- 2. 3つのレベル（統一感のあるアイコンセット） --- %>
  <div class="row justify-content-center mb-5 py-5 bg-white rounded-xl shadow-sm border mx-1">
    <div class="col-12 mb-4">
      <p class="text-muted small font-weight-bold text-uppercase tracking-widest">3 levels of feelings</p>
    </div>
    
    <%# Level 1: 独り言 %>
    <div class="col-4 col-md-3">
      <div class="status-icon-wrapper mb-2">
        <i class="fas fa-comment-dots fa-3x text-success opacity-75"></i>
      </div>
      <p class="font-weight-bold text-success mb-1">独り言</p>
      <span class="small text-muted">そっと置くだけ</span>
    </div>

    <%# Level 2: 聞いて %>
    <div class="col-4 col-md-3 border-left border-right">
      <div class="status-icon-wrapper mb-2">
        <i class="fas fa-bullhorn fa-3x text-warning opacity-75"></i>
      </div>
      <p class="font-weight-bold text-warning mb-1">聞いて</p>
      <span class="small text-muted">誰かに届けたい</span>
    </div>

    <%# Level 3: SOS %>
    <div class="col-4 col-md-3">
      <div class="status-icon-wrapper mb-2">
        <i class="fas fa-exclamation-circle fa-3x text-danger opacity-75"></i>
      </div>
      <p class="font-weight-bold text-danger mb-1">SOS</p>
      <span class="small text-muted">助けてほしい</span>
    </div>
  </div>

  <%# --- 3. さりげない安心のメッセージ --- %>
  <div class="mt-5 pt-3">
    <p class="text-muted small mb-0">
      <i class="fas fa-lock mr-1"></i> 投稿はログインしたメンバー内だけで共有されます
    </p>
    <p class="text-muted small mt-2">
      <%= link_to 'Yorisoiについてもっと詳しく', about_path, class: "text-success border-bottom" %>
    </p>
  </div>
</div>

<style>
  .rounded-xl { border-radius: 2rem; }
  .tracking-widest { letter-spacing: 0.3em; }
  .status-icon-wrapper {
    transition: transform 0.3s ease;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .status-icon-wrapper:hover {
    transform: scale(1.15);
  }
  .hover-up {
    transition: all 0.3s ease;
  }
  .hover-up:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-in-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
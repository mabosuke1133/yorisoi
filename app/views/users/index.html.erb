<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold text-secondary">
      <i class="fas fa-search me-2 text-primary"></i>仲間を探す
    </h2>
    <span class="badge bg-light text-dark border p-2">
      メンバー数: <%= @users.count %> 名
    </span>
  </div>

  <div class="row">
    <% @users.each do |user| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0 border-top border-primary border-3">
          <div class="card-body d-flex flex-column">
            
            <% # --- ユーザー基本情報 --- %>
            <div class="d-flex align-items-center mb-3">
              <div class="rounded-circle bg-light d-flex justify-content-center align-items-center shadow-sm" style="width: 50px; height: 50px;">
                <i class="fas fa-user text-secondary fa-lg"></i>
              </div>
              <div class="ms-3">
                <h6 class="mb-0 fw-bold text-dark"><%= user.name %></h6>
                <small class="text-muted">
                  <i class="far fa-clock me-1"></i><%= time_ago_in_words(user.updated_at) %>前に更新
                </small>
              </div>
            </div>

            <% # --- 自己紹介のチラ見せ --- %>
            <div class="introduction-box p-2 rounded bg-light mb-3 flex-grow-1">
              <p class="small text-secondary mb-0 line-clamp-3">
                <% if user.introduction.present? %>
                  <i class="fas fa-quote-left fa-xs me-1 text-primary opacity-50"></i>
                  <%= user.introduction.truncate(80) %>
                <% else %>
                  <span class="text-muted italic">「よろしくお願いします！」</span>
                <% end %>
              </p>
            </div>

            <% # --- 下段：アクション --- %>
            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
              <div class="text-primary small">
                <strong><%= user.posts.count %></strong> <span class="text-muted">投稿</span>
              </div>
              <%= link_to user_path(user), class: "btn btn-sm btn-primary rounded-pill px-4 shadow-sm" do %>
                詳しく見る <i class="fas fa-chevron-right ms-1"></i>
              <% end %>
            </div>

          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  /* 3行以上は省略する設定 */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card { transition: transform 0.2s; }
  .card:hover { transform: translateY(-5px); }
</style>
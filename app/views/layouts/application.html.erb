<!DOCTYPE html>
<html>
  <head>
    <title>Yorisoi</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Font Awesome %>
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css">

    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="<%= 'bg-light' if admin_signed_in? %>">
    <header>
      <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
        <div class="container">
          <%= link_to 'Yorisoi', root_path, class: 'navbar-brand font-weight-bold text-success' %>

          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ml-auto align-items-center">

              <% if admin_signed_in? %>
                <%# --- 管理者メニュー --- %>
                <li class="nav-item border-right pr-2 mr-2">
                  <span class="badge badge-dark">管理者モード</span>
                  <span class="small ml-2 font-weight-bold text-secondary"><%= current_admin.name %></span>
                </li>

                <li class="nav-item">
                  <%= link_to admin_consultations_path, class: 'nav-link' do %>
                    <i class="fas fa-comment-dots text-primary"></i> 個別相談一覧
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to groups_path, class: 'nav-link' do %>
                    <i class="fas fa-users text-primary"></i> チームルーム
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to posts_path, class: 'nav-link' do %>
                    <i class="fas fa-comments text-success"></i> みんなの広場
                  <% end %>
                </li>

                <li class="nav-item ml-2 border-left pl-2">
                  <%= link_to 'ユーザー管理', admin_users_path, class: 'nav-link small text-muted' %>
                </li>

                <li class="nav-item">
                  <%= link_to '投稿管理', admin_posts_path, class: 'nav-link small text-muted' %>
                </li>

                <li class="nav-item">
                  <%= link_to 'アカウント編集', edit_admin_registration_path, class: 'nav-link small text-muted' %>
                </li>

                <li class="nav-item ml-2">
                  <%= link_to 'ログアウト', destroy_admin_session_path, method: :delete, class: 'nav-link text-danger' %>
                </li>

              <% elsif user_signed_in? %>
                <%# --- 一般ユーザーメニュー --- %>
                <li class="nav-item">
                  <% current_consultation = current_user.consultations.last %>
                  <% if current_consultation %>
                    <%= link_to consultation_path(current_consultation), class: "btn btn-outline-primary btn-sm rounded-pill px-3 mr-3" do %>
                      <i class="fas fa-comment-dots"></i> 相談ルーム
                    <% end %>
                  <% else %>
                    <%= link_to consultations_path, data: { confirm: "メンターに個別相談を依頼しますか？" }, class: "btn btn-danger btn-sm rounded-pill px-3 shadow-sm mr-3" do %>
                      <i class="fas fa-exclamation-circle"></i> メンターに相談する
                    <% end %>
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to groups_path, class: 'nav-link' do %>
                    <i class="fas fa-users text-primary"></i> チームルーム
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to posts_path, class: 'nav-link' do %>
                    <i class="fas fa-comments text-success"></i> みんなの広場
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to users_path, class: "nav-link" do %>
                    <i class="fas fa-search"></i> 仲間を探す
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to 'マイページ', user_path(current_user), class: 'nav-link' %>
                </li>

                <li class="nav-item ml-2">
                  <%= link_to 'ログアウト', destroy_user_session_path, method: :delete, class: 'nav-link text-muted' %>
                </li>

              <% else %>
                <%# --- 未ログインメニュー --- %>
                <li class="nav-item"><%= link_to 'About', about_path, class: 'nav-link' %></li>
                <li class="nav-item"><%= link_to '新規登録', new_user_registration_path, class: 'nav-link font-weight-bold' %></li>
                <li class="nav-item"><%= link_to 'ログイン', new_user_session_path, class: 'nav-link' %></li>
                <li class="nav-item ml-3 border-left pl-3">
                  <%= link_to '管理者の方はこちら', new_admin_session_path, class: 'small text-muted' %>
                </li>
              <% end %>

            </ul>
          </div>
        </div>
      </nav>

      <%# フラッシュメッセージ省略（既存のまま） %>
      <div class="container">
        <% flash.each do |key, value| %>
          <% alert_class = key == 'notice' ? 'success' : 'danger' %>
          <div class="alert alert-<%= alert_class %> alert-dismissible fade show shadow-sm" role="alert">
            <%= value %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
        <% end %>
      </div>
    </header>

    <main class="container mb-5">
      <%= yield %>
    </main>
  </body>
</html>
<!DOCTYPE html>
<html>
  <head>
    <title>Yorisoi</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Font Awesome %>
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css">

    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="<%= 'bg-light' if admin_signed_in? %>">
    <header>
      <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
        <div class="container">
          <%= link_to 'Yorisoi', root_path, class: 'navbar-brand font-weight-bold text-success' %>
          
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ml-auto align-items-center">

              <% if admin_signed_in? %>
                <%# --- 管理者メニュー --- %>
                <li class="nav-item border-right pr-2 mr-2">
                  <span class="badge badge-dark">管理者モード</span>
                  <span class="small ml-2 font-weight-bold text-secondary">
                    <%= current_admin.name %>
                </li>
                <li class="nav-item">
                  <% unstarted_count = Issue.where(status: :unstarted).count %>
                  <%= link_to admin_issues_path, class: 'nav-link' do %>
                    <i class="fas fa-bell text-danger"></i> 相談一覧
                    <% if unstarted_count > 0 %>
                      <span class="badge badge-pill badge-danger"><%= unstarted_count %></span>
                    <% end %>
                  <% end %>
                </li>
                <li class="nav-item">
                  <%= link_to groups_path, class: 'nav-link' do %>
                    <i class="fas fa-users text-success"></i> チームルーム
                  <% end %>
                </li>
                <li class="nav-item">
                  <%= link_to posts_path, class: 'nav-link' do %>
                    <i class="fas fa-comments text-success"></i> みんなの広場
                  <% end %>
                </li>

                <li class="nav-item ml-2 border-left pl-2">
                  <%= link_to edit_admin_registration_path, class: 'nav-link text-secondary', title: '設定' do %>
                  <i class="fas fa-cog"></i> <span class="small">設定</span>
                <% end %>
                </li>

                <li class="nav-item ml-2 border-left pl-2">
                  <%= link_to 'ユーザー管理', admin_users_path, class: 'nav-link small text-muted' %>
                </li>
                <li class="nav-item">
                  <%= link_to '投稿管理', admin_posts_path, class: 'nav-link small text-muted' %>
                </li>
                <li class="nav-item ml-2">
                  <%= link_to 'ログアウト', destroy_admin_session_path, class: 'nav-link text-danger' %>
                </li>

              <% elsif user_signed_in? %>
                <%# --- 一般ユーザーメニュー --- %>

                <% current_issue = current_user.issues.where(status: [:unstarted, :in_progress]).last %>
                <li class="nav-item">
                  <% if current_issue %>
                    <div class="d-flex align-items-center">
                      <button class="btn btn-outline-secondary btn-sm rounded-pill px-3 mr-2" disabled title="現在、メンターが確認中です">
                        <i class="fas fa-paper-plane"></i> 送信済み
                      </button>
                      <% if current_issue.unstarted? %>
                        <%= link_to issue_path(current_issue), method: :delete, data: { confirm: "相談依頼を取り消しますか？" }, class: "text-muted small mr-3" do %>
                          <u>取り消す</u>
                        <% end %>
                      <% end %>
                    </div>
                  <% else %>
                    <%= link_to new_group_path(is_consultation: true), data: { confirm: "メンターに面談の相談を依頼しますか？" }, class: "btn btn-danger btn-sm rounded-pill px-3 shadow-sm mr-3" do %>
                      <i class="fas fa-exclamation-circle"></i> メンターに相談する
                    <% end %>
                  <% end %>
                </li>

                <li class="nav-item">
                  <%= link_to groups_path, class: 'nav-link' do %>
                    <i class="fas fa-users"></i> チームルーム
                  <% end %>
                </li>
                <li class="nav-item">
                  <%= link_to posts_path, class: 'nav-link' do %>
                    <i class="fas fa-comments text-success"></i>みんなの広場
                  <% end %>
                </li>
                <li class="nav-item ml-2">
                  <%= link_to favorites_path, class: 'nav-link' do %>
                    <i class="fas fa-heart text-danger"></i> いいね
                  <% end %>
                </li>
                <li class="nav-item">
                  <%= link_to 'マイページ', user_path(current_user), class: 'nav-link' %>
                </li>
                <li class="nav-item ml-2">
                  <%= link_to 'ログアウト', destroy_user_session_path, class: 'nav-link text-muted' %>
                </li>

              <% else %>
                <%# --- 未ログインメニュー --- %>
                <li class="nav-item"><%= link_to 'About', about_path, class: 'nav-link' %></li>
                <li class="nav-item"><%= link_to '新規登録', new_user_registration_path, class: 'nav-link font-weight-bold' %></li>
                <li class="nav-item"><%= link_to 'ログイン', new_user_session_path, class: 'nav-link' %></li>
                <li class="nav-item ml-3 border-left pl-3">
                  <%= link_to '管理者の方はこちら', new_admin_session_path, class: 'small text-muted' %>
                </li>
              <% end %>

            </ul>
          </div>
        </div>
      </nav>

      <%# フラッシュメッセージ %>
      <div class="container">
        <% flash.each do |key, value| %>
          <% alert_class = key == 'notice' ? 'success' : 'danger' %>
          <div class="alert alert-<%= alert_class %> alert-dismissible fade show shadow-sm" role="alert">
            <%= value %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
        <% end %>
      </div>
    </header>

    <main class="container mb-5">
      <%= yield %>
    </main>
  </body>
</html>
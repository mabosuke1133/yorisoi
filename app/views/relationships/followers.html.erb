<div class='container px-5 px-sm-0'>
  <h2 class="my-4">フォロワー</h2>
  <% if @users.exists? %>
    <table class='table'>
      <thead>
        <tr>
          <th>ユーザー名</th>
          <th></th>
          <th colspan="3"></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.name %></td>
            <td>フォロー数: <%= user.followings.count %></td>
            <td>フォロワー数: <%= user.followers.count %></td>
            <td><%= link_to '詳細', user_path(user), class: "btn btn-sm btn-outline-primary" %></td>
            <td><%= render "relationships/btn", user: user %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">フォロワーはまだいません。</p>
  <% end %>
</div>
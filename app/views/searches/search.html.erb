<div class="container mt-5">
  <%# --- 1. ヘッダーエリア --- %>
  <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
      <h2 class="font-weight-bold text-dark mb-0">
        <i class="fas fa-search text-success mr-2"></i>検索結果
      </h2>
      <p class="text-muted small mb-0 mt-1">
        キーワード「<span class="text-success font-weight-bold"><%= params[:word] %></span>」の検索結果
      </p>
    </div>
    <div>
      <%= link_to '広場に戻る', posts_path, class: "btn btn-outline-secondary btn-sm rounded-pill" %>
    </div>
  </div>

  <%# --- 2. 結果表示エリア --- %>
  <div class="row justify-content-center">
    <div class="col-lg-10">

      <% if @range == "User" %>
        <%# --- ユーザー検索の結果 --- %>
        <% if @users.any? %>
          <div class="row">
            <% @users.each do |user| %>
              <div class="col-md-6 mb-3">
                <div class="card h-100 shadow-sm border-0 rounded-xl hover-up transition">
                  <div class="card-body d-flex align-items-center">
                    <div class="bg-light-success text-success rounded-circle d-flex align-items-center justify-content-center mr-3" style="width: 50px; height: 50px;">
                      <i class="fas fa-user"></i>
                    </div>
                    <div class="flex-grow-1">
                      <h5 class="mb-0 font-weight-bold"><%= user.name %> さん</h5>
                      <span class="text-muted small">メンバー</span>
                    </div>
                    <%= link_to '詳細を見る', user_path(user), class: "btn btn-sm btn-success rounded-pill px-3" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%# ユーザー0件時 %>
          <div class="text-center py-5 mt-4 bg-white rounded-xl shadow-sm border">
            <h4 class="text-secondary">検索結果が見つかりませんでした</h4>
            <p class="text-muted mb-4">該当するユーザーはいませんでした。</p>
            <%= link_to "みんなの広場へ", posts_path, class: "btn btn-success rounded-pill px-4 shadow-sm" %>
          </div>
        <% end %>

      <% else %>
        <%# --- 投稿検索の結果 --- %>
        <% if @posts.any? %>
          <div class="row">
            <% @posts.each do |post| %>
              <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0 rounded-xl hover-up transition">
                  <div class="card-body p-4 d-flex flex-column">
                    
                    <%# 感情バッジ %>
                    <div class="mb-2">
                      <% case post.priority %>
                      <% when "soliloquy", 1 %>
                        <span class="badge badge-pill badge-success-light px-2 py-1 small">
                          <i class="fas fa-comment-dots mr-1"></i>独り言
                        </span>
                      <% when "sos", 3 %>
                        <span class="badge badge-pill badge-danger-light px-2 py-1 small">
                          <i class="fas fa-exclamation-circle mr-1"></i>SOS
                        </span>
                      <% else %>
                        <span class="badge badge-pill badge-warning-light px-2 py-1 small">
                          <i class="fas fa-bullhorn mr-1"></i>聞いて
                        </span>
                      <% end %>
                    </div>

                    <h5 class="card-title font-weight-bold text-dark mb-2 text-truncate">
                      <%= post.title %>
                    </h5>
                    
                    <p class="text-secondary small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5;">
                      <%= post.body %>
                    </p>
                    
                    <div class="d-flex justify-content-between align-items-center mt-auto border-top pt-3">
                      <span class="text-muted small">
                        <i class="fas fa-user-circle mr-1"></i><%= post.user.name %>
                      </span>
                      <%= link_to post_path(post), class: "text-success small font-weight-bold" do %>
                        詳細を見る <i class="fas fa-chevron-right ml-1"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%# 投稿0件時（RSpecがここを探します） %>
          <div class="text-center py-5 mt-4 bg-white rounded-xl shadow-sm border">
            <div class="mb-4">
              <i class="fas fa-search-minus fa-4x text-light"></i>
            </div>
            <h4 class="text-secondary">検索結果が見つかりませんでした</h4>
            <p class="text-muted mb-4">キーワードを変えて、もう一度試してみてください。</p>
            <%= link_to "みんなの広場へ", posts_path, class: "btn btn-success rounded-pill px-4 shadow-sm" %>
          </div>
        <% end %>
      <% end %>

    </div>
  </div>
</div>

<style>
  .rounded-xl { border-radius: 1rem; }
  .hover-up:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important; }
  .transition { transition: all 0.2s ease; }
  .bg-light-success { background-color: #e8f5e9; }
  .badge-success-light { background-color: #c8e6c9; color: #2e7d32; }
  .badge-warning-light { background-color: #ffe0b2; color: #ef6c00; }
  .badge-danger-light  { background-color: #ffcdd2; color: #c62828; }
</style>
<div class="container mt-4 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      
      <%# --- 1. ヘッダー --- %>
      <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-transparent p-0 mb-1">
              <li class="breadcrumb-item"><%= link_to 'トップ', root_path, class: "text-success" %></li>
              <li class="breadcrumb-item active" aria-current="page">個別相談ルーム</li>
            </ol>
          </nav>
          <h3 class="font-weight-bold text-dark mb-1">
            <i class="fas fa-comment-medical text-success mr-2"></i><%= @consultation.title %>
          </h3>
        </div>
        <div class="text-right">
          <% if @consultation.pending? %>
            <span class="badge badge-warning px-3 py-2 rounded-pill shadow-sm">受付中（メンター確認中）</span>
          <% elsif @consultation.processing? %>
            <span class="badge badge-success px-3 py-2 rounded-pill shadow-sm">対応中</span>
          <% else %>
            <span class="badge badge-secondary px-3 py-2 rounded-pill shadow-sm">対応完了</span>
          <% end %>
        </div>
      </div>

      <%# --- 2. メッセージ一覧エリア（チャット形式） --- %>
      <div class="chat-container mb-4 shadow-sm" style="border-radius: 20px; border: 1px solid #eee; min-height: 500px;">
        <% if @messages.any? %>
          <div class="p-3">
            <% @messages.each do |message| %>
              <%# 自分が送ったメッセージ（admin_idが空）かどうかを判定 %>
              <% is_mine = message.admin_id.blank? %>
              
              <div class="message-bubble <%= is_mine ? 'current-user' : 'other-user' %>">
                <div class="message-content">
                  <%# 相手（メンター）の発言時のみラベルを表示 %>
                  <% unless is_mine %>
                    <div class="message-name font-weight-bold text-secondary">メンター</div>
                  <% end %>

                  <div class="d-flex align-items-end <%= is_mine ? 'flex-row-reverse' : 'flex-row' %>">
                    <%# 吹き出し本体 %>
                    <div class="message-text shadow-sm">
                      <%= simple_format(message.body) %>
                    </div>
                    
                    <%# 送信時刻 %>
                    <span class="message-time">
                      <%= message.created_at.strftime('%H:%M') %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5 my-5">
            <i class="fas fa-hourglass-start fa-4x text-muted opacity-25 mb-4"></i>
            <h5 class="text-secondary">メンターからの返信をお待ちください</h5>
            <p class="text-muted small">内容を確認次第、こちらでチャットが開始されます。</p>
          </div>
        <% end %>
      </div>

      <%# --- 3. 投稿フォーム（対応中のみ表示） --- %>
      <% if @consultation.processing? %>
        <div class="card border-0 shadow-lg" style="border-radius: 20px;">
          <div class="card-body p-4 bg-white" style="border-radius: 20px;">
            <%= form_with model: [@consultation, @message], local: true do |f| %>
              <div class="form-group mb-3">
                <%= f.text_area :body, 
                                class: "form-control border-light bg-light p-3", 
                                rows: 3, 
                                placeholder: "メッセージを入力してください...", 
                                style: "resize: none; border-radius: 15px;" %>
              </div>
              <div class="text-right">
                <%= f.submit "送信する", class: "btn btn-success rounded-pill px-5 py-2 font-weight-bold shadow-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @consultation.pending? %>
        <div class="alert alert-warning text-center py-4 rounded-xl border-0 shadow-sm">
          <i class="fas fa-info-circle mr-2"></i> 現在、メンターが内容を確認しています。少々お待ちください。
        </div>
      <% end %>

    </div>
  </div>
</div>
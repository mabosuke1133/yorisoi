<div class="container mt-4 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      
      <%# --- 1. ヘッダー --- %>
      <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-transparent p-0 mb-1">
              <li class="breadcrumb-item"><%= link_to '相談一覧', consultations_path, class: "text-danger" %></li>
              <li class="breadcrumb-item active" aria-current="page">相談ルーム</li>
            </ol>
          </nav>
          <h3 class="font-weight-bold text-dark mb-1">
            <i class="fas fa-comment-medical text-danger mr-2"></i><%= @consultation.title %>
          </h3>
        </div>
        <div class="text-right">
          <% if @consultation.pending? %>
            <span class="badge badge-warning px-3 py-2 rounded-pill shadow-sm">受付中（メンター確認中）</span>
          <% elsif @consultation.processing? %>
            <span class="badge badge-success px-3 py-2 rounded-pill shadow-sm">対応中</span>
          <% else %>
            <span class="badge badge-secondary px-3 py-2 rounded-pill shadow-sm">対応完了（アーカイブ）</span>
          <% end %>
        </div>
      </div>

      <%# --- 2. メッセージ一覧エリア --- %>
      <div class="chat-board bg-light p-4 rounded-xl shadow-inner mb-4" style="height: 500px; overflow-y: auto; border: 1px solid #e9ecef;">
        <% if @messages.any? %>
          <% @messages.each do |message| %>
            <% is_mine = (user_signed_in? && message.user == current_user) %>
            <div class="mb-3 d-flex <%= is_mine ? 'justify-content-end' : 'justify-content-start' %>">
              <div class="p-3 shadow-sm" style="max-width: 75%; background-color: <%= is_mine ? '#fff5f5' : 'white' %>; border-radius: <%= is_mine ? '20px 20px 0px 20px' : '20px 20px 20px 0px' %>; border: 1px solid #dee2e6;">
                <div class="small text-muted mb-1" style="font-size: 0.7rem;">
                  <%= message.admin_id.present? ? "メンター" : "あなた" %>
                </div>
                <div class="text-dark" style="line-height: 1.6;">
                  <%= simple_format(message.body) %>
                </div>
                <div class="text-right small text-muted" style="font-size: 0.6rem;">
                  <%= message.created_at.strftime('%m/%d %H:%M') %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-5">
            <i class="fas fa-hourglass-start fa-3x text-muted opacity-25 mb-3"></i>
            <h5 class="text-secondary">メンターからの返信をお待ちください</h5>
            <p class="small text-muted">内容を確認次第、こちらでチャットが開始されます。</p>
          </div>
        <% end %>
      </div>

      <%# --- 3. 投稿フォーム（対応中のみ表示） --- %>
      <% if @consultation.processing? %>
        <div class="card border-0 shadow-lg" style="border-radius: 20px;">
          <div class="card-body p-4 bg-white" style="border-radius: 20px;">
            <%= form_with model: [@consultation, @message], local: true do |f| %>
              <div class="form-group mb-3">
                <%= f.text_area :body, class: "form-control border-light bg-light p-3", rows: 3, placeholder: "メッセージを入力...", style: "resize: none; border-radius: 15px;" %>
              </div>
              <div class="text-right">
                <%= f.submit "送信する", class: "btn btn-danger rounded-pill px-5 py-2 font-weight-bold" %>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @consultation.pending? %>
        <div class="alert alert-warning text-center py-4 rounded-xl border-0 shadow-sm">
          <i class="fas fa-info-circle mr-2"></i> 現在、メンターが内容を確認しています。少々お待ちください。
        </div>
      <% end %>

    </div>
  </div>
</div>
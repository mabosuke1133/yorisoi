<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="fas fa-users-cog me-2"></i>ユーザー管理一覧</h1>
    <span class="badge bg-dark">総ユーザー数: <%= @users.count %> 名</span>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 80px;">ID</th>
            <th>氏名</th>
            <th>メールアドレス</th>
            <th style="width: 150px;">登録日</th>
            <th style="width: 100px;" class="text-center">投稿数</th>
            <th style="width: 120px;" class="text-center">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td class="text-muted">#<%= user.id %></td>
              <td>
                <div class="fw-bold"><%= user.name %></div>
              </td>
              <td class="text-muted small"><%= user.email %></td>
              <td class="small">
                <%= user.created_at.strftime('%Y/%m/%d') %>
              </td>
              <td class="text-center">
                <span class="badge rounded-pill bg-light text-dark border">
                  <%= user.posts.count %>
                </span>
              </td>
              <td class="text-center">
                <%= link_to admin_user_path(user), class: "btn btn-sm btn-outline-primary shadow-sm" do %>
                  <i class="fas fa-search-plus me-1"></i>詳細
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
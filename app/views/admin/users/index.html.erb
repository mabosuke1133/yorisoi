<div class="container-fluid mt-4 pb-5">
  <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <h1 class="h3 font-weight-bold text-dark mb-0">
      <i class="fas fa-users-cog mr-2 text-success"></i>ユーザー管理一覧
    </h1>
    <span class="badge badge-dark shadow-sm px-3 py-2">
      <i class="fas fa-user-friends mr-1"></i>総ユーザー数: <%= @users.count %> 名
    </span>
  </div>

  <%# --- テーブルカード --- %>
  <div class="card shadow-sm border-0 rounded-lg">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="thead-light">
          <tr class="text-dark">
            <th style="width: 80px;" class="py-3">ID</th>
            <th class="py-3">氏名</th>
            <th class="py-3">メールアドレス</th>
            <th style="width: 150px;" class="py-3 text-center">登録日</th>
            <th style="width: 100px;" class="py-3 text-center">投稿数</th>
            <th style="width: 120px;" class="py-3 text-center">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td class="text-muted font-italic">#<%= user.id %></td>
              <td>
                <div class="font-weight-bold text-dark"><%= user.name %></div>
              </td>
              <td class="text-secondary small"><%= user.email %></td>
              <td class="small text-center text-muted">
                <%= user.created_at.strftime('%Y/%m/%d') %>
              </td>
              <td class="text-center">
                <span class="badge badge-pill badge-light border text-dark px-2">
                  <%= user.posts.count %>
                </span>
              </td>
              <td class="text-center">
                <%= link_to admin_user_path(user), class: "btn btn-sm btn-outline-primary shadow-sm rounded-pill px-3" do %>
                  <i class="fas fa-search-plus mr-1"></i>詳細
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  /* 管理画面用：テーブルの微調整 */
  .table thead th {
    border-top: none;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
  .rounded-lg { border-radius: 0.75rem; }
  .align-middle { vertical-align: middle !important; }
</style>
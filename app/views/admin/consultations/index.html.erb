<div class="container">
  <h2 class="mb-4">個別相談一覧</h2>

  <table class="table table-hover bg-white shadow-sm">
    <thead class="thead-light">
      <tr>
        <th>作成日時</th>
        <th>相談者</th>
        <th>タイトル</th>
        <th>ステータス</th>
        <th>アクション</th>
      </tr>
    </thead>
    <tbody>
      <%# 💡 ここを @issues から @consultations に変える %>
      <% @consultations.each do |consultation| %>
        <tr>
          <td><%= consultation.created_at.strftime('%Y/%m/%d %H:%M') %></td>
          <td><%= consultation.user.name %></td>
          <td><%= consultation.title %></td>
          <td>
            <%# 💡 status の判定を Consultation モデルの enum に合わせる %>
            <% if consultation.pending? %>
              <span class="badge badge-danger">未対応</span>
            <% elsif consultation.processing? %>
              <span class="badge badge-warning">対応中</span>
            <% elsif consultation.completed? %>
              <span class="badge badge-success">完了</span>
            <% end %>
          </td>
          <td>
            <% if consultation.pending? %>
              <%# ステータス更新ボタン %>
              <%= button_to '対応を開始', admin_consultation_path(consultation), method: :patch, class: "btn btn-primary btn-sm" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold"><i class="fas fa-comments text-primary me-2"></i>個別相談一覧</h2>
    <span class="badge rounded-pill bg-primary text-white px-3 py-2 shadow-sm">
      <i class="fas fa-list-ul me-1"></i> 総相談件数: <%= @consultations.count %> 件
    </span>
  </div>

  <div class="card shadow-sm border-0 overflow-hidden">
    <%# 💡 table-responsive を追加（スマホ対策） %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="bg-light text-nowrap">
          <tr>
            <th style="width: 170px;">作成日時</th>
            <th style="width: 140px;">相談者</th>
            <th>相談タイトル</th>
            <th style="width: 100px;" class="text-center">状態</th>
            <% # 💡 幅を 220px に少し広げました %>
            <th style="width: 220px;" class="text-center">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @consultations.each do |consultation| %>
            <tr>
              <td class="small text-muted"><%= consultation.created_at.strftime('%Y/%m/%d %H:%M') %></td>
              <td class="fw-bold"><%= consultation.user.name %></td>
              <td>
                <%= link_to consultation.title, admin_consultation_path(consultation), class: "text-decoration-none text-dark fw-bold" %>
              </td>
              <td class="text-center">
                <% if consultation.pending? %>
                  <span class="badge rounded-pill bg-danger">未対応</span>
                <% elsif consultation.processing? %>
                  <span class="badge rounded-pill bg-warning text-dark">対応中</span>
                <% elsif consultation.completed? %>
                  <span class="badge rounded-pill bg-success">完了</span>
                <% end %>
              </td>
              <td class="text-center">
                <% # 💡 flex-nowrap で絶対に折り返さない設定 %>
                <div class="d-flex justify-content-center align-items-center flex-nowrap">
                  
                  <%# --- 詳細・返信ボタン（mr-2で隙間を作る） --- %>
                  <%= link_to admin_consultation_path(consultation), class: "btn btn-sm btn-outline-primary shadow-sm mr-2" do %>
                    <i class="fas fa-door-open"></i> 詳細
                  <% end %>

                  <% if consultation.pending? %>
                    <%# 💡 form_class: "d-inline" これが横並びの決め手です %>
                    <%= button_to admin_consultation_path(consultation), 
                                  method: :patch, 
                                  class: "btn btn-sm btn-primary shadow-sm", 
                                  form_class: "d-inline",
                                  params: { consultation: { status: :processing } } do %>
                      対応開始
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<div class="container mt-4 pb-5">
  <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
    <div>
      <h4 class="font-weight-bold"><%= @consultation.user.name %> さんの相談</h4>
      <p class="text-muted mb-0">件名：<%= @consultation.title %></p>
    </div>
    
    <%# 💡 未対応の場合のみ「対応開始」ボタンを出す %>
    <% if @consultation.pending? %>
      <%= link_to 'この相談の対応を開始する', admin_consultation_path(@consultation), method: :patch, class: "btn btn-primary rounded-pill px-4 shadow-sm font-weight-bold" %>
    <% end %>
  </div>

  <%# メッセージ一覧（ユーザー側とほぼ同じ構造でOKですが、管理者は常に全メッセージが見えます） %>
  <div class="chat-board bg-light p-4 rounded-xl mb-4" style="height: 450px; overflow-y: auto; border: 1px solid #dee2e6;">
    <% if @consultation.pending? %>
      <div class="text-center py-5">
        <p class="text-muted">「対応を開始する」ボタンを押すと、チャットが利用可能になります。</p>
      </div>
    <% else %>
      <%# ここにメッセージを表示するループ（ユーザー側と同様） %>
      <% @messages.each do |message| %>
        <%# ... メッセージ表示ロジック ... %>
      <% end %>
    <% end %>
  </div>

  <%# 投稿フォーム（対応中のみ表示） %>
  <% if @consultation.processing? %>
    <%# ここに管理者用メッセージ投稿フォーム %>
  <% end %>
</div>

<%# --- 2. メッセージ一覧エリア（中身を追記） --- %>
<div class="chat-board bg-light p-4 rounded-xl mb-4" style="height: 450px; overflow-y: auto; border: 1px solid #dee2e6;">
  <% if @consultation.pending? %>
    <div class="text-center py-5">
      <i class="fas fa-lock fa-3x text-muted mb-3 opacity-25"></i>
      <p class="text-muted">「対応を開始する」ボタンを押すと、チャットが利用可能になります。</p>
    </div>
  <% else %>
    <% @messages.each do |message| %>
      <% is_admin_msg = message.admin_id.present? %>
      <div class="mb-3 d-flex <%= is_admin_msg ? 'justify-content-end' : 'justify-content-start' %>">
        <div class="p-3 shadow-sm" style="max-width: 75%; background-color: <%= is_admin_msg ? '#e3f2fd' : 'white' %>; border-radius: <%= is_admin_msg ? '20px 20px 0px 20px' : '20px 20px 20px 0px' %>; border: 1px solid #dee2e6;">
          <div class="small text-muted mb-1" style="font-size: 0.7rem;">
            <%= is_admin_msg ? "あなた（管理者）" : "#{@consultation.user.name} さん" %>
          </div>
          <div class="text-dark" style="line-height: 1.6;"><%= simple_format(message.body) %></div>
          <div class="text-right small text-muted" style="font-size: 0.6rem;"><%= message.created_at.strftime('%m/%d %H:%M') %></div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<%# --- 3. 投稿フォーム（対応中のみ表示） --- %>
<% if @consultation.processing? %>
  <div class="card border-0 shadow-lg" style="border-radius: 20px;">
    <div class="card-body p-4 bg-white" style="border-radius: 20px;">
      <%= form_with model: [:admin, @consultation, ConsultationMessage.new], local: true do |f| %>
        <div class="form-group mb-3">
          <%= f.text_area :body, class: "form-control border-light bg-light p-3", rows: 3, placeholder: "返信を入力...", style: "resize: none; border-radius: 15px;" %>
        </div>
        <div class="text-right">
          <%= f.submit "返信する", class: "btn btn-primary rounded-pill px-5 shadow-sm font-weight-bold" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
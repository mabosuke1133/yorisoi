<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="fas fa-clipboard-list me-2"></i>投稿管理一覧</h1>
    <span class="badge bg-dark">全 <%= @posts.count %> 件</span>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th style="width: 80px;">ID</th>
            <th style="width: 150px;">投稿者</th>
            <th>内容（冒頭）</th>
            <th style="width: 120px;">感情タイプ</th>
            <th style="width: 180px;">投稿日時</th>
            <th style="width: 150px;" class="text-center">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @posts.each do |post| %>
            <tr>
              <td class="text-muted">#<%= post.id %></td>
              <td>
                <% if post.user.present? %>
                  <%= link_to post.user.name, admin_user_path(post.user), class: "text-decoration-none fw-bold" %>
                <% else %>
                  <span class="text-muted">退会済みユーザー</span>
                <% end %>
              </td>
              <td>
                <span class="text-truncate d-inline-block" style="max-width: 300px;">
                  <%= post.body.truncate(40) %>
                </span>
              </td>
              <td>
                <% if post.priority.present? %>
                  <% 
                    badge_class = case post.priority
                                  when 'sos'       then 'bg-danger'
                                  when 'hearing'   then 'bg-success text-white'
                                  when 'soliloquy' then 'bg-info text-white'
                                  else 'bg-secondary'
                                  end
                  %>
                  <span class="badge <%= badge_class %> px-3 rounded-pill">
                    <%# 💡 Rails標準の翻訳機能(tメソッド)を直接使う %>
                    <%= t("enums.post.priority.#{post.priority}") %>
                  </span>
                <% else %>
                  <span class="badge bg-secondary px-3 rounded-pill">未設定</span>
                <% end %>
              </td>
              <td class="small text-muted">
                <%= post.created_at.strftime('%Y/%m/%d %H:%M') %>
              </td>
              <td class="text-center">
                <div class="btn-group">
                  <%= link_to post_path(post), class: "btn btn-sm btn-outline-secondary", title: "表示確認" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <%= link_to admin_post_path(post), method: :delete, data: { confirm: "この投稿を強制削除しますか？" }, class: "btn btn-sm btn-outline-danger", title: "削除" do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
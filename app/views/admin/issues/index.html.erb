<div class="container">
  <h2 class="mb-4">相談・面談依頼一覧</h2>

  <table class="table table-hover bg-white shadow-sm">
    <thead class="thead-light">
      <tr>
        <th>依頼日時</th>
        <th>ユーザー名</th>
        <th>ステータス</th>
        <th>アクション</th>
      </tr>
    </thead>
    <tbody>
      <% @issues.each do |issue| %>
        <tr>
          <td><%= issue.created_at.strftime('%Y/%m/%d %H:%M') %></td>
          <td><%= issue.user.name %></td>
          <td>
            <%# ステータスによって色を変える %>
            <% case issue.status %>
            <% when 'unstarted' %>
              <span class="badge badge-danger">未対応</span>
            <% when 'in_progress' %>
              <span class="badge badge-warning">対応中</span>
            <% when 'completed' %>
              <span class="badge badge-success">完了</span>
            <% end %>
          </td>
          <td>
            <% if issue.unstarted? %>
              <%= link_to '対応を開始する', admin_issue_path(issue, status: :in_progress), method: :patch, class: "btn btn-primary btn-sm" %>
            <% elsif issue.in_progress? %>
              <div class="d-flex align-items-center">
                <span class="badge badge-info mr-2">対応中</span>
                <%# 💡 追加：ステータスを未対応に戻すリセットボタン %>
                <%= link_to '解除', admin_issue_path(issue, status: :unstarted), method: :patch, class: "btn btn-outline-danger btn-sm", data: { confirm: "対応中を解除して、未対応に戻しますか？" } %>
              </div>
            <% elsif issue.completed? %>
              <span class="badge badge-success">完了</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
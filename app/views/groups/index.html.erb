<div class="container mt-4 pb-5">
  <% if user_signed_in? %>
    <%# --- 1. 参加・管理チームを1つに統合したセクション --- %>
    <div class="row mb-5 justify-content-center">
      <div class="col-md-10 col-lg-8">
        <div class="card shadow-sm border-0 bg-white rounded-xl">
          <div class="card-body p-4">
            <h5 class="font-weight-bold text-dark mb-4 text-center">
              <i class="fas fa-users-cog mr-2 text-primary"></i> あなたが参加しているチーム
            </h5>
            
            <% if @my_all_groups && @my_all_groups.any? %>
              <div class="list-group list-group-flush">
                <% @my_all_groups.each do |group| %>
                  <%= link_to group_path(group), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-3 py-3 mb-2 rounded-lg bg-light-hover transition" do %>
                    <span class="text-dark font-weight-bold">
                      <i class="fas fa-chevron-right small mr-2 text-muted"></i><%= group.name %>
                    </span>
                    
                    <%# 役割の出し分け %>
                    <% if group.owner == current_user %>
                      <span class="badge badge-success badge-pill px-3 shadow-sm">管理者</span>
                    <% else %>
                      <span class="badge badge-info badge-pill px-3 shadow-sm text-white">メンバー</span>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-4">
                <i class="fas fa-layer-group fa-2x text-light mb-3"></i>
                <p class="text-muted small mb-0">参加中のチームはまだありません。</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
    <hr class="my-5" style="border-top: 2px dashed #e9ecef;">
  <% end %>

  <%# --- 2. チーム一覧セクション --- %>
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="mb-3 mb-md-0">
      <h2 class="font-weight-bold text-dark d-inline-block mr-2 mb-0">すべてのチームルーム</h2>
      <span class="badge badge-pill badge-light text-muted p-2 border">
        <i class="fas fa-door-open mr-1"></i><%= @groups.count %> ルーム
      </span>
    </div>
    <% if user_signed_in? %>
      <%= link_to new_group_path, class: "btn btn-success rounded-pill px-4 shadow-sm font-weight-bold py-2" do %>
        <i class="fas fa-plus-circle mr-1"></i> チームを作成する
      <% end %>
    <% end %>
  </div>

  <% if admin_signed_in? %>
    <div class="alert alert-dark border-0 shadow-sm rounded-lg mb-4 py-3">
      <i class="fas fa-shield-alt mr-2 text-warning"></i> <strong>管理者モード：</strong> 全ルームの稼働状況を確認・管理できます。
    </div>
  <% end %>

  <div class="row">
  <% @groups.each do |group| %>
    <% if admin_signed_in? || (user_signed_in? && (current_user.following?(group.owner) || group.owner == current_user)) %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0 rounded-xl overflow-hidden hover-card transition">
          
          <%# 3人揃っているかどうかでヘッダーの色を変えると分かりやすい %>
          <% is_active = (group.users.count + 1) >= 3 %>
          <div class="card-header border-0 py-4 text-center text-white <%= is_active ? 'bg-success' : 'bg-secondary' %>">
            <i class="fas <%= is_active ? 'fa-comments' : 'fa-hourglass-half' %> fa-3x mb-2 opacity-8"></i>
            <h5 class="card-title font-weight-bold mb-0 mt-2"><%= group.name %></h5>
            <% unless is_active %>
              <div class="small mt-2"><i class="fas fa-users"></i> 3人揃うまで待機中...</div>
            <% end %>
          </div>

          <div class="card-body d-flex flex-column p-4">
            <p class="text-muted small mb-4 flex-grow-1" style="min-height: 4em; line-height: 1.6;">
              <%= truncate(group.introduction, length: 70) || "このチームの紹介文はまだ設定されていません。" %>
            </p>
            
            <div class="mt-auto">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="small text-secondary">
                  <i class="fas fa-user-circle mr-1"></i> <%= group.owner.name %>
                </div>
                <div class="badge badge-pill badge-light border px-2 py-1 text-muted" style="font-size: 0.75rem;">
                  <i class="fas fa-users mr-1"></i><%= group.users.count + 1 %>名
                </div>
              </div>

              <div class="d-flex align-items-center">
                <%# 💡 修正ポイント：3人揃っている時だけ「ルームに入る」ボタンを有効にする %>
                <% if is_active %>
                  <%= link_to group_path(group), class: "btn btn-success btn-block rounded-pill font-weight-bold py-2 shadow-sm" do %>
                    チャットに参加する <i class="fas fa-sign-in-alt ml-1"></i>
                  <% end %>
                <% else %>
                  <%# 3人未満の場合は、詳細ページ（参加申請ページ）への案内を出す %>
                  <%= link_to group_path(group), class: "btn btn-outline-secondary btn-block rounded-pill font-weight-bold py-2" do %>
                    詳細・参加申請 <i class="fas fa-info-circle ml-1"></i>
                  <% end %>
                <% end %>

                <% if (user_signed_in? && group.owner == current_user) || admin_signed_in? %>
                  <%= button_to group_path(group), method: :delete, data: { confirm: 'チームを削除してもよろしいですか？' }, class: "btn btn-link text-danger ml-2 p-0 border-0", title: "削除" do %>
                    <i class="fas fa-trash-alt p-2"></i>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<style>
  .rounded-xl { border-radius: 1.25rem; }
  .rounded-lg { border-radius: 0.85rem; }
  
  .transition {
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .hover-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
  }

  .bg-light-hover:hover {
    background-color: #f0f7f2 !important; /* ほんのり緑がかったホバー色 */
    transform: translateX(5px);
  }

  .opacity-8 { opacity: 0.8; }
  
  .btn-outline-success:hover {
    background-color: #28a745;
    color: white;
  }
</style>
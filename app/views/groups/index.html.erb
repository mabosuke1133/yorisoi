<div class="container mt-4 pb-5">
  <% if user_signed_in? %>
    <div class="row mb-5">
      <%# --- 管理中のチーム --- %>
      <div class="col-md-6 mb-4 mb-md-0">
        <div class="card shadow-sm border-0 bg-white rounded-xl">
          <div class="card-body p-4">
            <h5 class="font-weight-bold text-success mb-3">
              <i class="fas fa-user-shield mr-2"></i> 管理しているチーム
            </h5>
            <% if @my_groups.any? %>
              <div class="list-group list-group-flush">
                <% @my_groups.each do |group| %>
                  <%= link_to group_path(group), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 py-2" do %>
                    <span class="text-dark font-weight-bold"><i class="fas fa-chevron-right small mr-2 text-muted"></i><%= group.name %></span>
                    <span class="badge badge-success badge-pill px-3 shadow-sm">管理者</span>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted small mb-0 pl-1">管理中のチームはありません。</p>
            <% end %>
          </div>
        </div>
      </div>

      <%# --- 参加中のチーム --- %>
      <div class="col-md-6">
        <div class="card shadow-sm border-0 bg-white rounded-xl">
          <div class="card-body p-4">
            <h5 class="font-weight-bold text-info mb-3">
              <i class="fas fa-hands-helping mr-2"></i> 参加しているチーム
            </h5>
            <% if @joining_groups.any? %>
              <div class="list-group list-group-flush">
                <% @joining_groups.each do |group| %>
                  <%= link_to group_path(group), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 py-2" do %>
                    <span class="text-dark font-weight-bold"><i class="fas fa-chevron-right small mr-2 text-muted"></i><%= group.name %></span>
                    <span class="badge badge-info badge-pill px-3 shadow-sm text-white">メンバー</span>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted small mb-0 pl-1">参加中のチームはありません。</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
    <hr class="my-5" style="border-top: 2px dashed #e9ecef;">
  <% end %>

  <%# --- チーム一覧セクション --- %>
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="mb-3 mb-md-0">
      <h2 class="font-weight-bold text-dark d-inline-block mr-2 mb-0">すべてのチームルーム</h2>
      <span class="badge badge-pill badge-light text-muted p-2 border">
        <i class="fas fa-door-open mr-1"></i><%= @groups.count %> ルーム
      </span>
    </div>
    <% if user_signed_in? %>
      <%= link_to new_group_path, class: "btn btn-success rounded-pill px-4 shadow-sm font-weight-bold py-2" do %>
        <i class="fas fa-plus-circle mr-1"></i> チームを作成する
      <% end %>
    <% end %>
  </div>

  <% if admin_signed_in? %>
    <div class="alert alert-dark border-0 shadow-sm rounded-lg mb-4 py-3">
      <i class="fas fa-shield-alt mr-2 text-warning"></i> <strong>管理者モード：</strong> 全ルームの稼働状況を確認・管理できます。
    </div>
  <% end %>

  <div class="row">
    <% @groups.each do |group| %>
      <%# ロジック部分はそのまま維持 %>
      <% if group.issue_id.present? %>
        <% target_issue = Issue.find_by(id: group.issue_id) %>
        <% is_completed = target_issue&.completed? %>
      <% end %>

      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0 rounded-xl overflow-hidden hover-card transition">
          
          <%# カードヘッダー：色と文言を「寄り添い」に変更 %>
          <div class="card-header border-0 py-4 text-center text-white <%= is_completed ? 'bg-secondary' : 'bg-success' %>" style="position: relative;">
            <% if group.issue_id.present? %>
              <div style="position: absolute; top: 12px; right: 12px;">
                <% if is_completed %>
                  <span class="badge badge-pill badge-light text-secondary px-3 py-1 shadow-sm">アーカイブ済</span>
                <% else %>
                  <span class="badge badge-pill badge-warning text-white px-3 py-1 shadow-sm animate-pulse">寄り添い対応中</span>
                <% end %>
              </div>
            <% end %>

            <i class="fas <%= is_completed ? 'fa-archive' : 'fa-house-user' %> fa-3x mb-2 opacity-8"></i>
            <h5 class="card-title font-weight-bold mb-0 mt-2"><%= group.name %></h5>
          </div>

          <div class="card-body d-flex flex-column p-4">
            <p class="text-muted small mb-4 flex-grow-1" style="min-height: 4em; line-height: 1.6;">
              <% if is_completed %>
                <span class="badge badge-light border text-muted mb-2">サポート終了</span><br>
              <% end %>
              <%= truncate(group.introduction, length: 70) || "このチームの紹介文はまだ設定されていません。" %>
            </p>
            
            <div class="mt-auto">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="small text-secondary">
                  <i class="fas fa-user-circle mr-1"></i> <%= group.owner.name %>
                </div>
                <div class="badge badge-pill badge-light border px-2 py-1 text-muted" style="font-size: 0.75rem;">
                  <i class="fas fa-users mr-1"></i><%= group.users.count + 1 %>名
                </div>
              </div>

              <div class="d-flex align-items-center">
                <%= link_to group_path(group), class: "btn #{is_completed ? 'btn-outline-secondary' : 'btn-outline-success'} btn-block rounded-pill font-weight-bold py-2 shadow-sm" do %>
                  <%= is_completed ? '過去のログを確認' : 'ルームに入る' %> <i class="fas fa-sign-in-alt ml-1"></i>
                <% end %>

                <% if (user_signed_in? && group.owner == current_user) || admin_signed_in? %>
                  <%= button_to group_path(group), method: :delete, data: { confirm: 'チームを削除してもよろしいですか？' }, class: "btn btn-link text-danger ml-2 p-0 border-0", title: "削除" do %>
                    <i class="fas fa-trash-alt p-2"></i>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .rounded-xl { border-radius: 1.25rem; }
  .hover-card {
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .hover-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
  }
  .opacity-8 { opacity: 0.8; }
  .animate-pulse {
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.9; }
    100% { transform: scale(1); opacity: 1; }
  }
  .btn-outline-success:hover {
    background-color: #28a745;
    color: white;
  }
</style>
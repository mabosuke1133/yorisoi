<div class="container mt-4">
  <% if user_signed_in? %>
    <div class="row mb-5">
      <div class="col-md-6">
        <div class="card shadow-sm border-0 bg-white rounded-lg">
          <div class="card-body">
            <h5 class="font-weight-bold text-primary mb-3">
              <i class="fas fa-tools"></i> 管理中のチーム
            </h5>
            <% if @my_groups.any? %>
              <ul class="list-unstyled mb-0">
                <% @my_groups.each do |group| %>
                  <li class="mb-2 d-flex justify-content-between align-items-center p-2 bg-light rounded">
                    <%= link_to group.name, group_path(group), class: "text-dark font-weight-bold" %>
                    <span class="badge badge-primary px-3 shadow-sm">オーナー</span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted small mb-0">管理しているチームはありません。</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card shadow-sm border-0 bg-white rounded-lg">
          <div class="card-body">
            <h5 class="font-weight-bold text-success mb-3">
              <i class="fas fa-handshake"></i> 参加中のチーム
            </h5>
            <% if @joining_groups.any? %>
              <ul class="list-unstyled mb-0">
                <% @joining_groups.each do |group| %>
                  <li class="mb-2 d-flex justify-content-between align-items-center p-2 bg-light rounded">
                    <%= link_to group.name, group_path(group), class: "text-dark font-weight-bold" %>
                    <span class="badge badge-success px-3 shadow-sm">メンバー</span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted small mb-0">参加しているチームはありません。</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <hr class="my-5" style="border-top: 2px dashed #dee2e6;">
  <% end %>

  <%# --- 全グループ一覧（カード形式） --- %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="font-weight-bold text-dark d-inline-block mr-2">すべてのチーム</h2>
      <span class="badge badge-pill badge-light text-muted p-2 border">全 <%= @groups.count %> チーム</span>
    </div>
    <% if user_signed_in? %>
      <%= link_to new_group_path, class: "btn btn-success rounded-pill px-4 shadow-sm font-weight-bold" do %>
        <i class="fas fa-plus-circle"></i> 新規作成
      <% end %>
    <% end %>
  </div>

  <% if admin_signed_in? %>
    <div class="alert alert-info border-0 shadow-sm rounded-lg mb-4">
      <i class="fas fa-shield-alt"></i> 管理者モード：全チームの稼働状況を確認できます。
    </div>
  <% end %>

  <div class="row">
    <% @groups.each do |group| %>
  <%# 💡 絆（issue_id）がある場合だけ、相談データを取得する %>
  <% if group.issue_id.present? %>
    <% target_issue = Issue.find_by(id: group.issue_id) %>
    <% is_completed = target_issue&.completed? %>
  <% end %>

  <div class="col-md-6 col-lg-4 mb-4">
    <div class="card h-100 shadow-sm border-0 rounded-lg overflow-hidden hover-shadow transition">
      
      <%# 💡 修正：issue_id がある（個別相談）かつ 完了している場合だけ グレーにする %>
      <div class="card-header <%= (group.issue_id.present? && is_completed) ? 'bg-secondary' : 'bg-success' %> text-white py-4 text-center border-0" style="position: relative;">
        
        <%# 💡 修正：issue_id がある場合のみ、ステータスバッジを表示 %>
        <% if group.issue_id.present? %>
          <div style="position: absolute; top: 10px; right: 10px;">
            <% if is_completed %>
              <span class="badge badge-pill badge-light text-secondary shadow-sm">解決済み</span>
            <% else %>
              <span class="badge badge-pill badge-warning text-white shadow-sm">相談対応中</span>
            <% end %>
          </div>
        <% end %>

        <i class="fas <%= (group.issue_id.present? && is_completed) ? 'fa-check-circle' : 'fa-users' %> fa-3x mb-2 opacity-8"></i>
        <h5 class="card-title font-weight-bold mb-0"><%= group.name %></h5>
      </div>

      <div class="card-body d-flex flex-column">
        <p class="text-muted small mb-3 flex-grow-1" style="min-height: 3em;">
          <%# 💡 個別相談で完了済みの場合だけ [相談終了] と出す %>
          <% if group.issue_id.present? && is_completed %>
            <span class="text-success font-weight-bold">[相談終了]</span>
          <% end %>
          <%= truncate(group.introduction, length: 60) || "紹介文はまだありません。" %>
        </p>
        
        <div class="mt-auto pt-3 border-top">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <small class="text-muted">
              <i class="fas fa-user-circle"></i> オーナー: <strong><%= group.owner.name %></strong>
            </small>
            <span class="badge badge-pill badge-light border">メンバー <%= group.users.count + 1 %>名</span>
          </div>

          <div class="d-flex align-items-center">
            <%# 💡 修正：完了済みならボタンの色を少し変える %>
            <%= link_to group_path(group), class: "btn #{is_completed ? 'btn-outline-secondary' : 'btn-outline-success'} btn-block rounded-pill font-weight-bold" do %>
              <%= is_completed ? '過去の相談を見る' : 'ルームに入る' %> <i class="fas fa-arrow-right ml-1"></i>
            <% end %>

            <% if (user_signed_in? && group.owner == current_user) || admin_signed_in? %>
              <%= button_to group_path(group), method: :delete, data: { confirm: '本当に削除しますか？' }, class: "btn btn-link text-danger ml-3 p-0 border-0", title: "削除", style: "display: inline-block; vertical-align: middle;" do %>
                <i class="fas fa-trash-alt"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<style>
  .hover-shadow:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
  }
  .transition {
    transition: all 0.3s ease;
  }
  .opacity-8 {
    opacity: 0.8;
  }
</style>
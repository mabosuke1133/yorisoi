<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-9">
      
      <%# --- ヘッダーエリア：シンプルにタイトルのみ --- %>
      <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div>
          <h3 class="font-weight-bold text-dark mb-1"><%= @group.name %></h3>
          <p class="text-muted small mb-0">
            <i class="fas fa-lock text-success"></i> このルームはあなたとメンター以外には非公開です
          </p>
        </div>
        <%= link_to '一覧に戻る', groups_path, class: "btn btn-outline-secondary btn-sm rounded-pill" %>
      </div>

      <%# --- チャット掲示板エリア --- %>
      <div class="chat-board bg-white p-4 rounded shadow-sm mb-4" style="height: 500px; overflow-y: auto; border: 1px solid #eee;">
        <% if @group.group_messages.any? %>
          <% @group.group_messages.each do |message| %>
            <%# 自分が送ったか相手が送ったかで左右を分ける（オプション） %>
            <div class="mb-4 d-flex align-items-start">
              <div class="mr-3 text-center">
                <i class="fas fa-user-circle fa-2x text-secondary"></i>
                <div class="small text-muted" style="font-size: 0.7rem;">
                  <%= message.user.present? ? message.user.name : "メンター" %>
                </div>
              </div>
              <div class="p-3 rounded shadow-sm" style="max-width: 80%; background-color: #f8f9fa; border-radius: 15px !important;">
                <div class="card-text" style="line-height: 1.6;"><%= simple_format(message.body) %></div>
                <div class="text-right small text-muted mt-2" style="font-size: 0.6rem;">
                  <%= message.created_at.strftime('%m/%d %H:%M') %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-5">
            <i class="fas fa-comments fa-3x text-light mb-3"></i>
            <p class="text-muted">相談ルームが作成されました。<br>今の気持ちを自由に書き込んでみましょう。</p>
          </div>
        <% end %>
      </div>

      <%# --- 投稿フォーム --- %>
      <% if admin_signed_in? || (user_signed_in? && (@group.owner == current_user || @group.approved_users.include?(current_user))) %>
        <div class="card border-0 shadow-sm" style="border-radius: 15px;">
          <div class="card-body p-3 bg-light" style="border-radius: 15px;">
            <%= form_with model: [@group, GroupMessage.new], local: true do |f| %>
              <div class="input-group">
                <%= f.text_area :body, class: "form-control border-0 bg-light", rows: 2, placeholder: "メッセージを入力...", style: "resize: none; focus: none;" %>
                <div class="input-group-append align-items-center ml-2">
                  <%= f.submit "送信", class: "btn btn-primary px-4 rounded-pill shadow-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>

<%# --- 管理者向けの「完了」ボタン（任意） --- %>
<% if admin_signed_in? %>
  <div class="text-center mt-5">
    <p class="small text-muted">相談が解決した場合は、ステータスを完了にしてください</p>
    <%# ここに完了アクションへのリンクを置くことも可能です %>
  </div>
<% end %>
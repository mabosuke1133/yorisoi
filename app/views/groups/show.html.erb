<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-9">
      
      <%# --- ヘッダーエリア --- %>
      <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div>
          <h3 class="font-weight-bold text-dark mb-1">
            <%= @group.name %>
            <% if @issue&.completed? %>
              <span class="badge badge-success ml-2" style="font-size: 0.8rem;">完了済み</span>
            <% end %>
          </h3>
          <p class="text-muted small mb-0">
            <i class="fas fa-lock text-success"></i> 
            <% if admin_signed_in? %>
              <span class="badge badge-info">メンター専用画面</span> <%= @group.owner.name %>さんをサポート中
            <% else %>
              このルームはあなたとメンター以外には非公開です
            <% end %>
          </p>
        </div>
        <%= link_to '一覧に戻る', groups_path, class: "btn btn-outline-secondary btn-sm rounded-pill" %>
      </div>

      <%# --- チャット掲示板エリア --- %>
      <div class="chat-board bg-white p-4 rounded shadow-sm mb-4" style="height: 500px; overflow-y: auto; border: 1px solid #eee;">
        <% if @group.group_messages.any? %>
          <% @group.group_messages.each do |message| %>
            <div class="mb-4 d-flex align-items-start">
              <div class="mr-3 text-center">
                <% is_mentor = message.user&.name&.include?("メンター") %>
                <i class="fas fa-user-circle fa-2x <%= is_mentor ? 'text-primary' : 'text-secondary' %>"></i>
                <div class="small text-muted" style="font-size: 0.7rem;">
                  <% if user_signed_in? && message.user == current_user %>
                    あなた
                  <% elsif is_mentor %>
                    <span class="badge badge-primary" style="font-size: 0.6rem;">公式</span><br><%= message.user.name %>
                  <% else %>
                    <%= message.user.present? ? "#{message.user.name}さん" : "メンター" %>
                  <% end %>
                </div>
              </div>
              
              <div class="p-3 rounded shadow-sm" style="max-width: 80%; background-color: <%= is_mentor ? '#eef7ff' : '#f8f9fa' %>; border-radius: 15px !important;">
                <div class="card-text" style="line-height: 1.6;"><%= simple_format(message.body) %></div>
                <div class="text-right small text-muted mt-2" style="font-size: 0.6rem;">
                  <%= message.created_at.strftime('%m/%d %H:%M') %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-5">
            <i class="fas fa-comments fa-3x text-light mb-3"></i>
            <p class="text-muted">相談ルームが作成されました。<br>今の気持ちを自由に書き込んでみましょう。</p>
          </div>
        <% end %>
      </div>

      <%# --- 投稿フォームエリア --- %>
      <%# 相談が未完了、かつ権限がある場合のみ表示 %>
      <% if (@issue.nil? || !@issue.completed?) && (admin_signed_in? || (user_signed_in? && (@group.owner == current_user || @group.users.include?(current_user)))) %>
        <div class="card border-0 shadow-sm" style="border-radius: 15px;">
          <div class="card-body p-3 bg-light" style="border-radius: 15px;">
            <%= form_with model: [@group, GroupMessage.new], local: true do |f| %>
              <div class="input-group">
                <%= f.text_area :body, class: "form-control border-0 bg-light", rows: 2, placeholder: "メッセージを入力...", style: "resize: none; box-shadow: none;" %>
                <div class="input-group-append align-items-center ml-2">
                  <%= f.submit "送信", class: "btn btn-primary px-4 rounded-pill shadow-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @issue&.completed? %>
        <%# 完了済みの場合の案内メッセージ %>
        <div class="alert alert-secondary text-center shadow-sm py-3 mb-0" style="border-radius: 15px;">
          <i class="fas fa-lock mr-2 text-muted"></i>この相談は終了したため、新規投稿はできません。
        </div>
      <% end %>

    </div>
  </div>

  <%# --- 管理者向けの「完了」アクションエリア --- %>
  <%# 💡 管理者ログイン中かつ、Issueがまだ完了していない場合のみ表示 %>
  <% if admin_signed_in? && @issue && !@issue.completed? %>
    <div class="row justify-content-center mt-5 mb-5">
      <div class="col-md-9 text-center">
        <div class="d-inline-block p-4 bg-white rounded shadow-sm border">
          <i class="fas fa-check-circle text-success fa-2x mb-2"></i>
          <h6 class="font-weight-bold">対応ステータスの管理</h6>
          <p class="small text-muted mb-3">解決した場合はボタンを押してクローズしてください。</p>
          
          <%= link_to complete_admin_issue_path(@issue), 
              method: :patch, 
              data: { confirm: "この相談を「完了」にしてもよろしいですか？" }, 
              class: "btn btn-success rounded-pill px-4 shadow-sm" do %>
            <i class="fas fa-flag-checkered mr-1"></i> 相談を完了（クローズ）する
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

</div>
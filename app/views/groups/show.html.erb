<div class="container mt-4 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      
      <%# --- 1. チームヘッダー --- %>
      <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-transparent p-0 mb-1">
              <li class="breadcrumb-item"><%= link_to 'チーム一覧', groups_path, class: "text-success" %></li>
              <li class="breadcrumb-item active" aria-current="page">ルーム</li>
            </ol>
          </nav>
          <h3 class="font-weight-bold text-dark mb-1">
            <i class="fas fa-house-user text-success mr-2"></i><%= @group.name %>
          </h3>
          <p class="text-muted small mb-0">
            <i class="fas fa-users text-muted mr-1"></i> メンバー: <%= @approved_total %>名
          </p>
        </div>
        <div class="text-right">
          <% if @issue.nil? %>
            <span class="badge badge-info px-3 py-2 rounded-pill shadow-sm mb-2">チームトーク</span>
          <% elsif @issue.completed? %>
            <span class="badge badge-secondary px-3 py-2 rounded-pill shadow-sm mb-2">アーカイブ（閲覧専用）</span>
          <% else %>
            <span class="badge badge-success px-3 py-2 rounded-pill shadow-sm mb-2">寄り添い受付中</span>
          <% end %>
        </div>
      </div>

      <%# 💡 [判定用] メンバー（オーナー、承認済みメンバー、管理者）かどうか %>
      <% is_member = (user_signed_in? && (@group.owner == current_user || @group.users.include?(current_user))) || admin_signed_in? %>

      <%# --- 2. チーム掲示板エリア（メッセージ一覧） --- %>
      <div class="chat-board bg-light p-4 rounded-xl shadow-inner mb-4" style="height: 600px; overflow-y: auto; border: 1px solid #e9ecef;">
        <% if is_member %>
          <%# ⭕ メンバーのみ過去ログを表示 %>
          <% if @group.group_messages.any? %>
            <% @group.group_messages.each do |message| %>
              <% is_mine = (user_signed_in? && message.user == current_user) || (admin_signed_in? && message.admin_id == current_admin&.id) %>
              
              <div class="mb-3 <%= is_mine ? 'text-right' : 'text-left' %>">
                <div class="small text-muted mt-1" style="font-size: 0.7rem;">
                  <% if message.admin_id.present? %>
                    <span class="badge badge-info shadow-sm py-1 px-2" style="font-size: 0.6rem; vertical-align: middle;">メンター</span>
                    <span class="ml-1 font-weight-bold" style="color: #17a2b8;">よりそい担当</span>
                  <% else %>
                    <%= is_mine ? "あなた" : "#{message.user&.name}さん" %>
                  <% end %>
                </div>
                
                <div class="p-3 shadow-sm d-inline-block text-left" style="max-width: 75%; background-color: white; border-radius: <%= is_mine ? '20px 0px 20px 20px' : '0px 20px 20px 20px' %> !important; border: 1px solid #dee2e6;">
                  <div class="card-text text-dark" style="line-height: 1.6;">
                    <%= simple_format(message.body) %>
                  </div>
                  <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                    <span class="small text-muted" style="font-size: 0.65rem;">
                      <%= message.created_at.strftime('%m/%d %H:%M') %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-5 my-5">
              <div class="mb-3">
                <i class="fas fa-comments fa-4x text-muted opacity-25"></i>
              </div>
              <h5 class="text-secondary">まだ寄り添いメッセージがありません</h5>
            </div>
          <% end %>
        <% else %>
          <%# 🔒 メンバー外へのロック表示 %>
          <div class="text-center py-5 my-5">
            <div class="mb-4">
              <i class="fas fa-lock fa-4x text-muted opacity-50"></i>
            </div>
            <h5 class="text-dark font-weight-bold">このチームのやり取りは非公開です</h5>
            <p class="text-muted small">
              メンバーとして承認されると、今までのやり取りが見られるようになります。<br>
              まずは下のボタンから参加申請を送ってみましょう。
            </p>
          </div>
        <% end %>
      </div>

      <%# --- 3. 投稿フォーム or 参加申請エリア --- %>
      <% if is_member %>
        
        <% if @is_chat_available %>
          <%# 🔓 条件クリア：チャット可能 %>
          <% if @issue.nil? || !@issue.completed? %>
            <div class="card border-0 shadow-lg" style="border-radius: 20px;">
              <div class="card-body p-4 bg-white" style="border-radius: 20px;">
                <%= form_with model: [@group, @group_message], local: true do |f| %>
                  <% if admin_signed_in? %>
                    <%= f.hidden_field :admin_id, value: current_admin.id %>
                  <% end %>
                  <div class="form-group mb-3">
                    <label class="small font-weight-bold text-muted mb-2">
                      <i class="fas fa-pen-nib mr-1"></i> 今のきもちをチームに届ける
                    </label>
                    <%= f.text_area :body, class: "form-control border-light bg-light p-3", rows: 3, placeholder: "ここに入力...", style: "resize: none; border-radius: 15px;" %>
                  </div>
                  <div class="d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                      <i class="fas fa-lock-open mr-1"></i> このチームのメンバーだけに公開されます
                    </div>
                    <%= f.submit "メッセージを送る", class: "btn btn-success rounded-pill px-5 py-2 font-weight-bold shadow-sm" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        
        <% elsif !@issue&.completed? %>
          <%# ⏳ 3人未満：準備中 %>
          <div class="alert alert-info text-center shadow-sm py-4 rounded-xl border-0" style="background-color: #e3f2fd; color: #0d47a1;">
            <p class="mb-0 font-weight-bold">
              <i class="fas fa-users-cog mr-2"></i> 
              現在チームを準備中です。あと <strong><%= 3 - @approved_total %>名</strong> の承認でチャットが開始されます。
            </p>
            <small class="d-block mt-2 opacity-75">※密室状態を防ぐため、3名以上の参加が必要です。</small>
          </div>
        <% end %>

        <% if @issue&.completed? %>
          <div class="alert alert-secondary text-center shadow-sm py-4 rounded-xl mt-3">
            <p class="mb-0 font-weight-bold text-secondary">
              <i class="fas fa-archive mr-2"></i> このルームの寄り添い対応は終了し、閲覧用として保存されました。
            </p>
          </div>
        <% end %>

      <% else %>
        <%# 📩 メンバー外：参加申請ボタン %>
        <div class="card border-0 shadow-lg" style="border-radius: 20px;">
          <div class="card-body p-4 p-md-5 text-center bg-white" style="border-radius: 20px;">
            <h5 class="font-weight-bold mb-3">このチームに参加しますか？</h5>
            <p class="text-muted mb-4 small">
              参加申請を送ると、オーナーが確認後に承認を行います。<br>
              承認されるとチャットへの参加と過去ログの閲覧が可能になります。
            </p>
            
            <% if @group.permits.exists?(user_id: current_user.id) %>
              <div class="btn btn-secondary rounded-pill px-5 py-3 font-weight-bold shadow-sm disabled">
                <i class="fas fa-hourglass-start mr-2"></i> 申請済み（オーナーの承認待ち）
              </div>
            <% else %>
              <%= link_to group_permits_path(@group), method: :post, class: "btn btn-success rounded-pill px-5 py-3 font-weight-bold shadow-sm transition hover-lift" do %>
                <i class="fas fa-hand-holding-heart mr-2"></i> このチームに参加申請を送る
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

  <%# --- 管理者向け「完了」操作 --- %>
  <% if admin_signed_in? && @issue && !@issue.completed? %>
    <div class="row justify-content-center mt-5">
      <div class="col-md-10 text-center">
        <div class="p-4 bg-white rounded-xl shadow-sm border border-success">
          <h6 class="font-weight-bold text-success"><i class="fas fa-heart mr-1"></i> 寄り添い状況の管理</h6>
          <p class="small text-muted mb-3">状況が落ち着き、フォローが完了した場合はルームをアーカイブできます。</p>
          <%= link_to complete_admin_issue_path(@issue), 
                method: :patch, 
                data: { confirm: "このチームの寄り添いを「完了」にしてもよろしいですか？" }, 
                class: "btn btn-outline-success rounded-pill px-4 btn-sm" do %>
            寄り添いフォローを完了する
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  .rounded-xl { border-radius: 1.5rem; }
  .shadow-inner {
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.06) !important;
  }
  .breadcrumb-item + .breadcrumb-item::before {
    content: ">";
    color: #ced4da;
  }
  .chat-board::-webkit-scrollbar {
    width: 6px;
  }
  .chat-board::-webkit-scrollbar-thumb {
    background-color: #ced4da;
    border-radius: 10px;
  }
  .hover-lift:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(40, 167, 69, 0.2) !important;
  }
  .transition { transition: all 0.2s ease; }
</style>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <h2 class="text-center mb-4 font-weight-bold">新規会員登録</h2>

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "users/shared/error_messages", resource: resource %>

            <div class="form-group mb-3">
              <%= f.label :name, "ユーザー名", class: "small font-weight-bold" %>
              <%= f.text_field :name, autofocus: true, class: "form-control form-control-lg", placeholder: "よりそい 太郎" %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :email, "メールアドレス", class: "small font-weight-bold" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control form-control-lg" %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :password, "パスワード", class: "small font-weight-bold" %>
              <% if @minimum_password_length %>
                <span class="badge badge-light text-muted"><%= @minimum_password_length %>文字以上</span>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <div class="form-group mb-4">
              <%= f.label :password_confirmation, "パスワード（確認用）", class: "small font-weight-bold" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <div class="actions">
              <%= f.submit "新規登録する", class: "btn btn-success btn-lg btn-block w-100 shadow-sm" %>
            </div>
          <% end %>

          <div class="mt-4 pt-3 border-top text-center">
            <p class="small text-muted mb-2">既にアカウントをお持ちの方</p>
            <%= link_to "ログインはこちら", new_session_path(resource_name), class: "btn btn-outline-secondary btn-sm px-4" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

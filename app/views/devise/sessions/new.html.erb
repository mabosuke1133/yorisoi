<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <h2 class="text-center mb-4 font-weight-bold">ログイン</h2>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="form-group mb-3">
              <%= f.label :email, "メールアドレス", class: "small font-weight-bold" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "example@mail.com" %>
            </div>

            <div class="form-group mb-4">
              <%= f.label :password, "パスワード", class: "small font-weight-bold" %>
              <%= f.password_field :password, autocomplete: "current-password", class: "form-control form-control-lg" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="form-group form-check mb-4">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "ログイン状態を保持する", class: "form-check-label small text-muted" %>
              </div>
            <% end %>

            <div class="actions">
              <%= f.submit "ログインする", class: "btn btn-success btn-lg btn-block w-100 shadow-sm" %>
            </div>
          <% end %>

          <div class="mt-4 pt-3 border-top text-center">
            <p class="small text-muted mb-2">アカウントをお持ちでない方はこちら</p>
            <%= link_to "新規会員登録", new_registration_path(resource_name), class: "btn btn-outline-success btn-sm px-4" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

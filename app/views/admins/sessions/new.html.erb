<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <%# border-0 と shadow-sm でスッキリした高級感を統一 %>
      <div class="card shadow-sm border-0">
        <%# p-5 で内側の余白をゆったりと確保 %>
        <div class="card-body p-5">
          <h2 class="text-center mb-4 font-weight-bold">管理者ログイン</h2>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="form-group mb-3">
              <%= f.label :email, "メールアドレス", class: "small font-weight-bold" %>
              <%# form-control-lg で入力欄を大きく統一 %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :password, "パスワード", class: "small font-weight-bold" %>
              <%= f.password_field :password, autocomplete: "current-password", class: "form-control form-control-lg" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="form-group form-check mb-4">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "ログイン情報を保存する", class: "form-check-label small text-muted" %>
              </div>
            <% end %>

            <div class="actions mb-4">
              <%# btn-lg でボタンの高さも入力欄と合わせる %>
              <%= f.submit "ログインする", class: "btn btn-primary btn-lg btn-block w-100 shadow-sm" %>
            </div>
          <% end %>

          <%# 区切り線をより薄く、スマートに %>
          <div class="mt-4 pt-3 border-top text-center">
            <p class="small text-muted mb-2">管理者アカウントをお持ちでない場合</p>
            <%= link_to "管理者アカウントの新規作成", new_admin_registration_path, class: "btn btn-outline-primary btn-sm px-4" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="text-center mb-4">管理者ログイン</h2>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="form-group mb-3">
              <%= f.label :email, "メールアドレス" %><br />
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :password, "パスワード" %><br />
              <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="form-group form-check mb-3">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "ログイン情報を保存する", class: "form-check-label" %>
              </div>
            <% end %>

            <div class="actions mb-4">
              <%= f.submit "ログインする", class: "btn btn-primary btn-block w-100" %>
            </div>
          <% end %>

          <hr>

          <%# --- 「新規登録はこちら」のボタン --- %>
          <div class="text-center mt-4">
            <p class="small text-muted mb-2">管理者アカウントをお持ちでない場合</p>
            <%= link_to "管理者アカウントの新規作成", new_admin_registration_path, class: "btn btn-outline-secondary btn-sm" %>
          </div>

          <div class="mt-3 text-center small">
            <%= render "admins/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <h2 class="text-center mb-4 font-weight-bold">管理者新規登録</h2>

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "admins/shared/error_messages", resource: resource %>

            <div class="form-group mb-3">
              <%= f.label :name, "管理者名", class: "small font-weight-bold" %>
              <%= f.text_field :name, autofocus: true, class: "form-control form-control-lg" %>
              <small class="text-muted">※相談ルームなどで表示される名前になります。</small>
            </div>

            <div class="form-group mb-3">
              <%= f.label :email, "メールアドレス", class: "small font-weight-bold" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :password, "パスワード", class: "small font-weight-bold" %>
              <% if @minimum_password_length %>
                <span class="badge badge-light text-muted font-weight-normal ml-1"><%= @minimum_password_length %>文字以上</span>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :password_confirmation, "パスワード（確認用）", class: "small font-weight-bold" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <%# --- 招待コード（ここもサイズを合わせて微調整） --- %>
            <div class="form-group mb-4 p-3 bg-light border rounded">
              <%= f.label :invitation_code, "管理者招待コード", class: "small font-weight-bold" %>
              <%= f.text_field :invitation_code, class: "form-control form-control-lg", placeholder: "コードを入力してください" %>
              <small class="text-muted">※正しいコードを入力しないと登録できません。</small>
            </div>

            <div class="actions">
              <%= f.submit "管理者として登録する", class: "btn btn-danger btn-lg btn-block w-100 shadow-sm" %>
            </div>
          <% end %>

          <div class="mt-4 pt-3 border-top text-center">
            <p class="small text-muted mb-2">管理者アカウントをお持ちの方</p>
            <%= link_to "ログインはこちら", new_admin_session_path, class: "btn btn-outline-primary btn-sm px-4" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <h2 class="text-center mb-4 font-weight-bold">管理者情報編集</h2>

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            <%= render "admins/shared/error_messages", resource: resource %>

            <%# --- 管理者名の編集 --- %>
            <div class="form-group mb-3">
              <%= f.label :name, "管理者名", class: "small font-weight-bold" %>
              <%= f.text_field :name, autofocus: true, class: "form-control form-control-lg" %>
            </div>

            <%# --- メールアドレスの編集 --- %>
            <div class="form-group mb-3">
              <%= f.label :email, "メールアドレス", class: "small font-weight-bold" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control form-control-lg" %>
            </div>

            <%# --- 確認待ちメールアドレス（Devise設定用） --- %>
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="alert alert-warning small">
                現在、次のアドレスの確認待ちです: <%= resource.unconfirmed_email %>
              </div>
            <% end %>

            <%# --- 新しいパスワード（変更したい場合のみ） --- %>
            <div class="form-group mb-3">
              <%= f.label :password, "新しいパスワード", class: "small font-weight-bold" %>
              <i class="text-muted small">(変更しない場合は空欄のままにしてください)</i>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg" %>
              <% if @minimum_password_length %>
                <p class="small text-muted mb-0"><%= @minimum_password_length %>文字以上必要です</p>
              <% end %>
            </div>

            <div class="form-group mb-3">
              <%= f.label :password_confirmation, "新しいパスワード（確認用）", class: "small font-weight-bold" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <%# --- 現在のパスワード（更新には必須） --- %>
            <div class="form-group mb-4 p-3 bg-light border rounded">
              <%= f.label :current_password, "現在のパスワード", class: "small font-weight-bold" %>
              <i class="text-muted small">(変更を反映するには現在のパスワードが必要です)</i>
              <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control form-control-lg" %>
            </div>

            <div class="actions">
              <%= f.submit "情報を更新する", class: "btn btn-primary btn-lg btn-block w-100 shadow-sm" %>
            </div>
          <% end %>

          <%# --- 退会エリア --- %>
          <div class="mt-5 pt-4 border-top text-center">
            <h5 class="text-danger font-weight-bold small">管理者の退会</h5>
            <p class="text-muted small">アカウントを削除すると元に戻せません。</p>
            <%= button_to "アカウントを削除する", registration_path(resource_name), 
                data: { confirm: "本当に退会しますか？", turbo_confirm: "本当に退会しますか？" }, 
                method: :delete, 
                class: "btn btn-outline-danger btn-sm" %>
          </div>

          <div class="text-center mt-3">
            <%= link_to "戻る", :back, class: "text-muted small" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

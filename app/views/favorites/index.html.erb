<div class="container mt-5">
  <%# ナビゲーション・ヘッダー %>
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-transparent p-0">
      <li class="breadcrumb-item"><%= link_to "マイページ", user_path(current_user), class: "text-success" %></li>
      <li class="breadcrumb-item active" aria-current="page">寄り添い済み一覧</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <div>
      <h1 class="h3 font-weight-bold text-dark mb-0">
        <i class="fas fa-heart text-danger mr-2"></i>寄り添った投稿
      </h1>
      <p class="text-muted small mb-0 mt-1">あなたがこれまでに共感を示した投稿の記録です。</p>
    </div>
    <span class="badge badge-pill badge-success px-3 py-2">
      全 <%= @favorite_posts.count %> 件
    </span>
  </div>

  <%# 投稿カード一覧 %>
  <div class="row">
    <% if @favorite_posts.exists? %>
      <% @favorite_posts.each do |post| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <%# hover-shadow は独自のcssで少し浮かせるとさらに良くなります %>
          <div class="card h-100 shadow-sm border-0 rounded-lg overflow-hidden transition-hover">
            
            <%# 画像エリア：高さ固定で見栄えを統一 %>
            <div class="position-relative bg-light text-center" style="height: 180px; overflow: hidden;">
              <% if post.image.attached? %>
                <%= image_tag post.image, class: "w-100 h-100", style: "object-fit: cover;" %>
              <% else %>
                <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                  <i class="fas fa-image fa-3x opacity-25"></i>
                </div>
              <% end %>
              <%# 感情レベルを画像上にフローティング表示 %>
              <div class="position-absolute" style="top: 10px; left: 10px;">
                <span class="badge badge-info shadow-sm px-2 py-1">
                  <i class="fas fa-leaf"></i> Lv.<%= post.emotion_level %>
                </span>
              </div>
            </div>

            <%# ボディエリア %>
            <div class="card-body">
              <h5 class="card-title font-weight-bold text-dark text-truncate">
                <%= post.title %>
              </h5>
              <p class="card-text text-secondary small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                <%# 投稿本文の冒頭を表示（もしあれば） %>
                <%= post.body if defined?(post.body) %>
              </p>
              <div class="d-flex align-items-center">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mr-2" style="width: 30px; height: 30px;">
                  <i class="fas fa-user text-secondary small"></i>
                </div>
                <span class="text-muted small font-weight-bold"><%= post.user.name %> さん</span>
              </div>
            </div>

            <%# フッターエリア %>
            <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center pb-3 pt-0">
              <div class="d-flex align-items-center">
                <span class="small text-muted mr-3" title="コメント数">
                  <i class="far fa-comment-dots text-primary"></i> <%= post.post_comments.count %>
                </span>
                <span class="small" title="寄り添い解除">
                  <%= render 'favorites/favorite_btn', post: post %>
                </span>
              </div>
              <%= link_to '詳細を見る', post_path(post), class: 'btn btn-outline-success btn-sm rounded-pill px-3' %>
            </div>

          </div>
        </div>
      <% end %>
    <% else %>
      <%# データがない時の空状態表示（Empty State） %>
      <div class="col-12 text-center py-5 mt-4">
        <div class="mb-4">
          <i class="fas fa-heart-broken fa-4x text-light"></i>
        </div>
        <h4 class="text-secondary">まだ寄り添った投稿がありません</h4>
        <p class="text-muted mb-4">他のスタッフの投稿を読んで、共感の気持ちを届けてみましょう。</p>
        <%= link_to posts_path, class: "btn btn-success rounded-pill px-4 shadow-sm" do %>
          <i class="fas fa-search mr-2"></i>投稿を探しに行く
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<style>
  /* ホバー時に少し浮き上がらせる演出 */
  .transition-hover {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .transition-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
  }
</style>
<div class="container mt-4">
  <%# ヘッダー部分 %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="font-weight-bold text-success">いいねした投稿一覧</h1>
    <span class="badge badge-pill badge-light text-muted">全 <%= @favorite_posts.count %> 件</span>
  </div>

  <%# 投稿カード一覧 %>
  <div class="row">
    <% if @favorite_posts.exists? %>
      <% @favorite_posts.each do |post| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm border-0 rounded-lg overflow-hidden">
            
            <%# 画像エリア %>
            <div class="post-image-container bg-light text-center">
              <% if post.image.attached? %>
                <%= image_tag post.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
              <% else %>
                <div class="py-5 text-muted"><i class="fas fa-image"></i> 画像なし</div>
              <% end %>
            </div>

            <%# ボディエリア %>
            <div class="card-body">
              <div class="mb-2">
                <span class="badge badge-info">感情レベル: <%= post.emotion_level %></span>
              </div>
              
              <h5 class="card-title font-weight-bold text-dark mb-1">
                <%= post.title %>
              </h5>
              
              <p class="text-muted small mb-0">
                <i class="fas fa-user"></i> <%= post.user.name %> さん
              </p>
            </div>

            <%# フッターエリア %>
            <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center pb-3">
              <div class="d-flex align-items-center">
                <span class="small text-muted mr-3">
                  <i class="far fa-comment-dots"></i> <%= post.post_comments.count %>
                </span>
                <span class="small">
                  <%= render 'favorites/favorite_btn', post: post %>
                </span>
              </div>
              <%= link_to '詳細を見る', post_path(post), class: 'btn btn-outline-success btn-sm rounded-pill px-3' %>
            </div>

          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12 text-center py-5">
        <p class="text-muted">いいねした投稿はまだありません。</p>
        <%= link_to "タイムラインを見てみる", posts_path, class: "btn btn-success rounded-pill" %>
      </div>
    <% end %>
  </div>
</div>